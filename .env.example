# IdiamPro / SecondBrainWare environment variables
# Copy this file to .env.local and fill in real values.

# Google Gemini API key (server-side AI calls via Genkit) — powers the FREE
# text features (generate/expand/translate/etc.). This is a DEV/founder key.
GEMINI_API_KEY=

# ── COMPANY (funded) keys for the PAID-per-use premium features ────────────
# These are DELIBERATELY SEPARATE from the personal keys above. The paid
# premium features (OpenAI TTS voice, AssemblyAI transcription, Imagen image
# generation) NEVER fall back to a personal/founder key for end users — they
# run ONLY on the user's own key (BYOK) or one of these COMPANY keys.
#
# LEAVE BLANK until a real, funded SecondBrainWare billing account exists.
# While blank, non-BYOK end users are cleanly blocked (asked to add their own
# key / upgrade) and the free "N-lifetime taste" is OFF. Setting a key here
# turns the company-funded free taste ON, billed to the company — never the
# founder's personal card. (For local dev testing you MAY point one of these
# at a personal key; that is a deliberate dev choice, not end-user code.)
COMPANY_OPENAI_API_KEY=
COMPANY_ASSEMBLYAI_API_KEY=
COMPANY_GEMINI_API_KEY=

# Sentry crash + error reporting.
# Leave blank to disable Sentry entirely (the SDKs become no-ops).
# Set the same value in Vercel for the web build, and in your local
# .env.local for Electron/dev. NEXT_PUBLIC_SENTRY_DSN is exposed to the
# browser bundle; it can be the same DSN as SENTRY_DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional: only needed if you want source maps uploaded at build time.
SENTRY_AUTH_TOKEN=

# Clerk authentication (web billing via Stripe, iOS via RevenueCat — later).
# Leave blank to disable auth entirely. With no publishable key the app
# behaves exactly as it does today: every user is anonymous / free tier,
# no ClerkProvider is mounted, no auth network calls, zero runtime
# overhead (same gating philosophy as Sentry above).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is exposed to the browser bundle and is
# the single switch that turns auth on. CLERK_SECRET_KEY is server-side
# only (used by later auth/billing phases).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Invite-only signup allowlist.
# Comma-separated emails allowed to sign up. Leave blank to disable the
# allowlist (dev / open-beta). Example:
#   INVITE_ALLOWLIST=alice@example.com,bob@example.com
# Matching is exact + case-insensitive. No wildcards, no domain matching.
# Enforced in two places: the signup page (UX gate via /api/invite-check)
# and the Clerk user.created webhook (defense in depth — deletes the
# account immediately if the email isn't on the list).
INVITE_ALLOWLIST=

# Admin allowlist — who can reach the /admin console + admin data APIs.
# Comma-separated emails, exact match + case-insensitive. Admin access is
# enforced ENTIRELY on the server: a signed-in Clerk user whose email is on
# this list. There is no client flag to flip.
# IMPORTANT: if left blank, this DEFAULTS to hjachter@gmail.com so the
# founder is never locked out. Set it in Vercel to add/replace admins:
#   ADMIN_EMAILS=hjachter@gmail.com,teammate@example.com
ADMIN_EMAILS=

# Billing — Stripe (web payments) + RevenueCat (iOS subscriptions).
# Leave ALL of these blank to disable billing entirely. With no keys set
# the app behaves EXACTLY as it does today: every user is on the free tier,
# no Stripe SDK is loaded, no billing network calls, the checkout/webhook
# API routes early-return "billing not configured", zero runtime overhead
# (same gating philosophy as Sentry and Clerk above).
#
# Stripe (web). STRIPE_SECRET_KEY presence is the single switch that turns
# Stripe on (server-side only, never exposed to the browser).
# Find in: Stripe Dashboard > Developers > API keys.
STRIPE_SECRET_KEY=
# Webhook signing secret used to verify inbound Stripe webhook calls.
# Find in: Stripe Dashboard > Developers > Webhooks > [your endpoint] > Signing secret.
STRIPE_WEBHOOK_SECRET=
# Publishable key — safe to expose to the browser. Used for Apple Pay / Google Pay UX.
# Find in: Stripe Dashboard > Developers > API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Launch-model Stripe Price ids (price_...). Three products, three prices:
# Find in: Stripe Dashboard > Products > [product] > Pricing.
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_STUDENT_MONTHLY=
# Legacy aliases — kept for backward compatibility with older billing-config.
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
#
# RevenueCat. Two keys are involved:
#   NEXT_PUBLIC_REVENUECAT_KEY — public SDK key for the browser / iOS Capacitor plugin.
#     Find in: RevenueCat Dashboard > Project settings > API keys > Public.
#   REVENUECAT_API_KEY — server-side REST key the Stripe webhook uses to
#     provision entitlements after a successful charge.
#     Find in: RevenueCat Dashboard > Project settings > API keys > Secret.
NEXT_PUBLIC_REVENUECAT_KEY=
REVENUECAT_API_KEY=
# RevenueCat entitlement identifiers configured in the dashboard.
# Find in: RevenueCat Dashboard > Entitlements.
REVENUECAT_ENTITLEMENT_PRO=
REVENUECAT_ENTITLEMENT_STUDENT=
# Legacy alias — kept for backward compatibility (was used for the older
# 'premium' entitlement; the launch model uses 'student' + 'pro' instead).
REVENUECAT_ENTITLEMENT_PREMIUM=

# Onboarding emails — PrivateEmail SMTP (transactional email) + Clerk
# webhook (signup trigger) + Vercel Cron (drip schedule). Same env-gating
# philosophy as Sentry / Clerk / Stripe: leave SMTP_HOST / SMTP_USER /
# SMTP_PASS blank to disable the entire email layer with zero runtime
# overhead. With any of those missing, every send is a no-op log line
# ("[email/send] SMTP not configured — skipping email send."); signup,
# the webhook, and the cron job all keep working unchanged in dev.
#
# SMTP host — for PrivateEmail (Namecheap-hosted) this is
# "mail.privateemail.com".
SMTP_HOST=
# SMTP port — 465 for implicit TLS (default, recommended), 587 for
# STARTTLS. Strings are coerced to numbers; unset falls back to 465.
SMTP_PORT=
# SMTP mailbox username (full email address, e.g. welcome@2ndbrainware.com).
SMTP_USER=
# SMTP mailbox password.
SMTP_PASS=
# From address shown to recipients. Optional — defaults to SMTP_USER if
# unset (RFC-recommended: the From address should match an address the
# SMTP user is authorised to send from). To send FROM the support desk, set
# BOTH this to "IdiamPro Support <support@2ndbrainware.com>" AND point
# SMTP_USER/SMTP_PASS at the support@2ndbrainware.com mailbox — otherwise the
# From will not match the authenticated mailbox and PrivateEmail will reject.
EMAIL_FROM=
# Reply-To on every outgoing app email. Optional — defaults to the shared
# support desk (support@2ndbrainware.com). Reply-To has no auth requirement,
# so replies route to support even while From is still another mailbox.
EMAIL_REPLY_TO=
# Admin recipient for "new applicant" and feedback-notification emails.
# Optional — defaults to howard@2ndbrainware.com.
EMAIL_TO_ADMIN=
# --- Legacy fallback ---------------------------------------------------
# RESEND_API_KEY — was the previous email backend (Resend HTTP API). No
# longer read by the runtime; kept documented in case we ever pivot back.
# RESEND_API_KEY=
# Public site origin used to build unsubscribe URLs in outgoing emails.
# Example: https://2ndbrainware.com (no trailing slash).
NEXT_PUBLIC_APP_URL=
# Secret used to HMAC-sign unsubscribe tokens. Any sufficiently random
# string (e.g. `openssl rand -hex 32`). Production MUST set this.
EMAIL_UNSUBSCRIBE_SECRET=
# Optional override for the unsubscribe-state JSON file location.
# Defaults to .idiampro/unsubscribed.json under the process cwd.
EMAIL_UNSUBSCRIBE_STORE_PATH=
# Clerk webhook signing secret (Clerk Dashboard > Webhooks > [endpoint] >
# Signing Secret). Subscribe the endpoint to `user.created`. Leave blank
# to disable signature verification (dev/stub mode — logs a warning).
CLERK_WEBHOOK_SECRET=
# Vercel Cron secret — Vercel Cron requests carry
# `Authorization: Bearer <CRON_SECRET>`. Add the same value as a Vercel
# project env var. Leave blank to disable auth on the cron route
# (dev/stub mode — logs a warning).
CRON_SECRET=

# Vercel KV (Upstash Redis) — durable storage for applicants, feedback, beta
# Pro grants, and unsubscribe state in production. Required on Vercel because
# the serverless filesystem (/var/task) is read-only and the legacy
# .idiampro/*.json files fail with ENOENT on the first write.
#
# Setup: in the Vercel dashboard, Storage tab > Create Database > KV. Vercel
# auto-injects KV_REST_API_URL, KV_REST_API_TOKEN, and a few read-only
# variants into every connected project. Redeploy after attaching the store.
#
# Leave blank in dev / Electron — the storage adapter falls back to atomic
# JSON file writes under `.idiampro/` (same data, same shape, locally
# writable). With BOTH KV vars missing AND a read-only filesystem, every
# write becomes a no-op + warning log so signups don't 500.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional override for the file-backend data directory. Defaults to
# `.idiampro/` under the process cwd. Only honored when KV is not configured.
IDIAMPRO_DATA_DIR=
