    "creator-outreach-w1": {
      "id": "creator-outreach-w1",
      "name": "Jason Hamilton — The Nerdy Novelist",
      "content": "<p><strong>Platform + URL:</strong> YouTube &mdash; https://www.youtube.com/@TheNerdyNovelist (also X: https://x.com/StoryHobbit)</p><p><strong>Approx reach:</strong> 56K+ subscribers (early-2025 figure)</p><p><strong>Covers:</strong> The largest channel specifically about AI for creative/fiction writing; tutorials on outlining, drafting, and beating writer's block with AI. Runs the \"Story Hacker AI\" community.</p><p><strong>IdiamPro angle:</strong> <em>Highest-fit name on this list.</em> IdiamPro's \"outline &rarr; AI builds the table of contents &rarr; populates every chapter\" is his exact workflow, productized.</p>",
      "type": "note",
      "parentId": "creator-outreach-writing",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "12.2.1"
    },
    "creator-outreach-w2": {
      "id": "creator-outreach-w2",
      "name": "Joanna Penn — The Creative Penn",
      "content": "<p><strong>Platform + URL:</strong> Blog/podcast &mdash; https://www.thecreativepenn.com</p><p><strong>Approx reach:</strong> Not verified (NYT/USA Today bestselling author, 40+ books)</p><p><strong>Covers:</strong> The definitive voice on making a living as an author; recurring, credible coverage of \"AI for authors\" done tastefully.</p><p><strong>IdiamPro angle:</strong> Trusted, non-hype authority; a demo of full-book generation done with craft would resonate with her \"artisan author\" framing.</p>",
      "type": "note",
      "parentId": "creator-outreach-writing",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "12.2.2"
    },
    "creator-outreach-w3": {
