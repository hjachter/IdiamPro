    "root": {
      "id": "root",
      "name": "IdiamPro Marketing 2",
      "content": "<h2>IdiamPro - AI-Native Outlining Platform</h2><p>This outline contains all marketing materials, product specifications, workflows, and action items for the IdiamPro marketing effort.</p><p><strong>Tagline:</strong> <em>\"Think in outlines. Create with AI.\"</em></p>",
      "type": "root",
      "parentId": null,
      "childrenIds": [
        "overview",
        "feat-multimedia-shipped-2026-06-11",
