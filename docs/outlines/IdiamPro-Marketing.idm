    "creator-outreach-g5": {
      "id": "creator-outreach-g5",
      "name": "AI for Education — EdTech",
      "content": "<p><strong>Platform + URL:</strong> https://www.aiforeducation.io</p><p><strong>Covers:</strong> Educator-facing AI resource/community.</p><p><strong>IdiamPro angle:</strong> IdiamPro's \"for students + teachers\" outputs (lesson structure &rarr; explainer video/diagram) fit their audience.</p><p><strong>&#9888; Candid note:</strong> EdTech surfaced mostly as tools/orgs (Eduaide, ISTE+ASCD) rather than individual creator-voices. This is the best single verified target; individual EdTech-AI creators are a gap.</p>",
      "type": "note",
      "parentId": "creator-outreach-genre",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "12.6.5"
    },
    "creator-outreach-visuals": {
      "id": "creator-outreach-visuals",
      "name": "AI Visuals & Diagrams (thin category — caution)",
      "content": "<p><strong>Candid caution:</strong> this is the thinnest category for AI-native individual creators. Most channels that surfaced are traditional art educators who <em>reference</em> AI, not creators whose whole voice is AI-generated visuals/diagrams. Included honestly with that caveat; recommend deeper hand-verification before outreach here. Diagrams / visual-thinking specifically is a gap &mdash; no strong AI-native individual creator verified. (Proko / Sinix / Drawing Wiff Waffles / SonaDrawzStuffYT surfaced in AI-art roundups but read as traditional-art channels &mdash; left out to avoid overstating fit.)</p>",
      "type": "document",
      "parentId": "creator-outreach",
      "childrenIds": [
        "creator-outreach-vi1",
        "creator-outreach-vi2"
      ],
      "isCollapsed": false,
      "prefix": "12.7"
    },
    "creator-outreach-vi1": {
      "id": "creator-outreach-vi1",
      "name": "Marco Bucci",
      "content": "<p><strong>Platform + URL:</strong> YouTube &mdash; https://www.youtube.com/@marcobucci</p><p><strong>Approx reach:</strong> Not verified</p><p><strong>Covers:</strong> Pro concept artist; color theory, character design; blends traditional art with AI tools.</p><p><strong>IdiamPro angle:</strong> Explicitly bridges human craft + AI; would appreciate IdiamPro's AI-graphics + auto-diagram outputs.</p>",
      "type": "note",
      "parentId": "creator-outreach-visuals",
      "childrenIds": [],
      "isCollapsed": false,
