    "04c17db1-48b4-4a16-8a8b-71d5c2698b01": {
      "id": "04c17db1-48b4-4a16-8a8b-71d5c2698b01",
      "name": "3 · AI &amp; Language Models",
      "content": "<p>Cloud + local intelligence.</p>",
      "type": "text",
      "parentId": "d7d1cdbc-8e30-47c8-8647-45db78d59c3e",
      "childrenIds": [
        "68786994-2d8a-4014-a6dc-e6fdfccdd0dc",
