{
  "id": "45b26a76-c975-4c55-ace2-cd27f0fc825d",
  "name": "IdeaM -- Dependencies",
  "rootNodeId": "d7d1cdbc-8e30-47c8-8647-45db78d59c3e",
  "nodes": {
    "d7d1cdbc-8e30-47c8-8647-45db78d59c3e": {
      "id": "d7d1cdbc-8e30-47c8-8647-45db78d59c3e",
      "name": "IdeaM -- Dependencies",
      "content": "<p><strong>Third-Party Dependency &amp; Vendor Register.</strong> Every external product IdeaM relies on, what breaks if it fails, and OUR recurring responsibilities to keep each one doing what we expect. Created 2026-07-06 from a full codebase sweep. Pairs with the reliability principle: assume every dependency will fail, and design so a failure is harmless and visible.</p><p><em>Review this register on a set cadence (see “Our Standing Responsibilities”). Update it whenever a vendor is added, removed, or its status changes.</em></p>",
      "type": "text",
      "parentId": null,
      "childrenIds": [
        "b911545c-a1fa-4afd-90a7-08ede6617109",
        "a4e61d38-02d5-467d-9594-f9055ce351ef",
        "04c17db1-48b4-4a16-8a8b-71d5c2698b01",
        "52927a25-0757-4db2-be6d-cca86abe394f",
        "7c14b36c-461a-477a-805a-19ced7b1a2c4",
        "ea12f614-1cda-44d1-ab84-b3c9abe37bbf",
        "a78bb8c6-d8ba-4af2-b771-85026d17e295",
        "5eefab25-3016-4043-a94b-8fe0c4dec581",
        "c5cd707a-7389-4e20-a1b7-c821a992e878",
        "5b411fe6-2f09-4480-bc1f-eb0720e85b9a"
      ],
      "prefix": ""
    },
    "b911545c-a1fa-4afd-90a7-08ede6617109": {
      "id": "b911545c-a1fa-4afd-90a7-08ede6617109",
      "name": "1 · Hosting &amp; Infrastructure",
      "content": "<p>Where the app runs and stores server-side data.</p>",
      "type": "text",
      "parentId": "d7d1cdbc-8e30-47c8-8647-45db78d59c3e",
