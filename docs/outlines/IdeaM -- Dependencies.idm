    "a78bb8c6-d8ba-4af2-b771-85026d17e295": {
      "id": "a78bb8c6-d8ba-4af2-b771-85026d17e295",
      "name": "7 · Native Mobile &amp; Desktop",
      "content": "<p>App shells + distribution.</p>",
      "type": "text",
      "parentId": "d7d1cdbc-8e30-47c8-8647-45db78d59c3e",
      "childrenIds": [
        "c0f56792-c618-451c-9abb-64f520722bc8",
        "4c054d19-cbf0-46dc-8864-f8eafeed61b8",
        "dfe22b1b-2bf9-4986-b33d-869aeb0ed7c7",
        "0cae495f-838b-45d6-bbab-aa2612795ca9"
      ],
