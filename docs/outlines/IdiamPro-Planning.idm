    "comp-notion": {
      "id": "comp-notion",
      "name": "Notion",
      "content": "<p><strong>Strengths:</strong></p><p>\u2022 All-in-one workspace (docs, databases, wikis)</p><p>\u2022 Beautiful UI, strong brand</p><p>\u2022 Large community, templates marketplace</p><p>\u2022 $10B valuation, well-funded</p><p></p><p><strong>Weaknesses:</strong></p><p>\u2022 Slow performance (cloud-first architecture)</p><p>\u2022 Feature bloat (trying to do everything)</p><p>\u2022 Not great for pure outlining</p><p>\u2022 Expensive for teams ($10-15/user/mo)</p><p>\u2022 Privacy concerns (all data on their servers)</p><p></p><p><strong>Our Advantage:</strong></p><p>Faster, local-first, focused on outlining not databases, better mobile gestures</p>",
      "type": "document",
      "parentId": "competitors",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.2.1"
    },
    "comp-obsidian": {
      "id": "comp-obsidian",
      "name": "Obsidian",
      "content": "<p><strong>Strengths:</strong></p><p>\u2022 Local-first (Markdown files)</p><p>\u2022 Strong privacy story</p><p>\u2022 Plugin ecosystem</p><p>\u2022 Passionate community</p><p>\u2022 Profitable, bootstrapped</p><p></p><p><strong>Weaknesses:</strong></p><p>\u2022 Markdown-centric (not true outliner)</p><p>\u2022 Steep learning curve</p><p>\u2022 Mobile app is clunky</p><p>\u2022 UI feels dated</p><p>\u2022 Not great for non-technical users</p><p></p><p><strong>Our Advantage:</strong></p><p>Better mobile experience, true outliner UX, more approachable for mainstream users</p>",
      "type": "document",
      "parentId": "competitors",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.2.2"
    },
    "comp-workflowy": {
      "id": "comp-workflowy",
      "name": "WorkFlowy",
      "content": "<p><strong>Strengths:</strong></p><p>\u2022 Pure outliner (our closest competitor)</p><p>\u2022 Simple, fast</p><p>\u2022 Generous free tier</p><p>\u2022 Long-standing (since 2010)</p><p></p><p><strong>Weaknesses:</strong></p><p>\u2022 Dated UI/UX</p><p>\u2022 Limited formatting options</p><p>\u2022 No local storage option</p><p>\u2022 Slow innovation pace</p><p>\u2022 Mobile app needs work</p><p></p><p><strong>Our Advantage:</strong></p><p>Modern UI, rich node types (task, code, link), local-first option, better iOS gestures, tags/colors</p>",
      "type": "document",
      "parentId": "competitors",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.2.3"
    },
    "comp-roam": {
      "id": "comp-roam",
      "name": "Roam Research",
      "content": "<p><strong>Strengths:</strong></p><p>\u2022 Bi-directional links (graph view)</p><p>\u2022 Daily notes workflow</p><p>\u2022 Strong early adopter community</p><p>\u2022 Raised $9M</p><p></p><p><strong>Weaknesses:</strong></p><p>\u2022 Expensive ($15/mo)</p><p>\u2022 Cloud-only</p><p>\u2022 Performance issues</p><p>\u2022 High churn reported</p><p>\u2022 Niche audience (researchers)</p><p></p><p><strong>Our Advantage:</strong></p><p>More affordable, local-first, better performance, broader appeal beyond academics</p>",
      "type": "document",
      "parentId": "competitors",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.2.4"
    },
    "comp-others": {
      "id": "comp-others",
      "name": "Other Competitors",
      "content": "<p><strong>Dynalist:</strong> WorkFlowy clone, similar weaknesses</p><p></p><p><strong>Logseq:</strong> Open source Roam alternative, free but technical</p><p></p><p><strong>Craft:</strong> Beautiful but Mac-only, expensive ($10/mo)</p><p></p><p><strong>Bear:</strong> Note-taking not outlining, Apple-only</p><p></p><p><strong>Evernote:</strong> Legacy player, declining, not an outliner</p><p></p><p><strong>OneNote:</strong> Microsoft, free but clunky, enterprise-focused</p>",
      "type": "document",
      "parentId": "competitors",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.2.5"
    },
    "positioning": {
      "id": "positioning",
      "name": "Market Positioning",
      "content": "<p><strong>Our Position</strong></p><p>\"The modern outliner for professionals who value speed, privacy, and simplicity.\"</p><p></p><p><strong>Positioning Matrix</strong></p><p></p><p>Feature-Rich \u2194 Simple</p><p>\u2022 Notion (feature-rich, complex)</p><p>\u2022 Obsidian (powerful, steep curve)</p><p>\u2022 IdiamPro (sweet spot: powerful but elegant)</p><p>\u2022 WorkFlowy (simple but limited)</p><p></p><p>Cloud-First \u2194 Local-First</p><p>\u2022 Notion, Roam (cloud-only)</p><p>\u2022 IdiamPro (local-first, cloud optional)</p><p>\u2022 Obsidian, Logseq (local-only)</p><p></p><p><strong>Value Propositions</strong></p><p>1. <strong>Privacy First:</strong> Your data stays on your device (local .idm files or folder sync)</p><p>2. <strong>Cross-Platform Done Right:</strong> Same experience on Mac, iOS, Web, Windows</p><p>3. <strong>No Vendor Lock-In:</strong> Plain JSON files you own forever</p><p>4. <strong>Keyboard + Touch Mastery:</strong> Optimized for both power users and mobile</p><p>5. <strong>Fast & Focused:</strong> Does one thing exceptionally well (outlining)</p><p></p><p><strong>Messaging</strong></p><p>Tagline: \"Your ideas, organized. Your way.\"</p><p></p><p>Elevator pitch: \"IdiamPro is a professional outlining app that works the way you think\u2014fast, flexible, and private. Unlike bloated note-taking apps, we focus on structured thinking. Unlike simple outliners, we give you rich formatting, tags, and cross-platform sync without sacrificing speed.\"</p>",
      "type": "document",
      "parentId": "market-analysis",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.3"
    },
    "user-personas": {
      "id": "user-personas",
