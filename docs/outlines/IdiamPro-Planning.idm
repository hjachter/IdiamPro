    "persona-writer": {
      "id": "persona-writer",
      "name": "Sarah the Writer",
      "content": "<p><strong>Demographics:</strong> 32, freelance writer/author, remote</p><p><strong>Pain Points:</strong> Needs to organize research, outline articles/books, distraction-free writing</p><p><strong>Current Tools:</strong> Scrivener (too complex), Google Docs (not structured enough), Notion (too slow)</p><p><strong>Why IdiamPro:</strong> Fast outlining for book chapters, seamless iOS writing on the go, tags for organizing sources</p><p><strong>Willingness to Pay:</strong> High ($10-15/mo)</p>",
      "type": "document",
      "parentId": "user-personas",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.4.1"
    },
    "persona-pm": {
      "id": "persona-pm",
      "name": "Marcus the Product Manager",
      "content": "<p><strong>Demographics:</strong> 38, PM at tech company, hybrid work</p><p><strong>Pain Points:</strong> Planning sprints, organizing product roadmaps, meeting notes, PRDs</p><p><strong>Current Tools:</strong> Notion (team uses it but he finds it slow), Linear (for tickets only)</p><p><strong>Why IdiamPro:</strong> Fast capture during meetings, hierarchy for roadmap planning, templates for recurring docs</p><p><strong>Willingness to Pay:</strong> Medium (company pays or expense)</p>",
      "type": "document",
      "parentId": "user-personas",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.4.2"
    },
    "persona-student": {
      "id": "persona-student",
      "name": "Emily the Grad Student",
      "content": "<p><strong>Demographics:</strong> 24, PhD candidate, tight budget</p><p><strong>Pain Points:</strong> Literature review organization, thesis outlining, citation management</p><p><strong>Current Tools:</strong> Google Docs, Zotero, scattered notes</p><p><strong>Why IdiamPro:</strong> Free tier good enough, organize papers by tags, outline dissertation chapters</p><p><strong>Willingness to Pay:</strong> Low (maybe $5/mo student discount)</p>",
      "type": "document",
      "parentId": "user-personas",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.4.3"
    },
    "persona-dev": {
      "id": "persona-dev",
      "name": "Alex the Developer",
      "content": "<p><strong>Demographics:</strong> 29, software engineer, privacy-conscious</p><p><strong>Pain Points:</strong> Planning architecture, documenting APIs, learning notes, project planning</p><p><strong>Current Tools:</strong> Obsidian (loves Markdown), VS Code, Notion (team)</p><p><strong>Why IdiamPro:</strong> Local-first appeals to privacy values, code node type, keyboard shortcuts</p><p><strong>Willingness to Pay:</strong> Medium (values good tools)</p>",
      "type": "document",
      "parentId": "user-personas",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": "2.4.4"
    },
    "product-strategy": {
      "id": "product-strategy",
      "name": "Product Strategy",
      "content": "<p>Product vision, roadmap, and development priorities</p>",
      "type": "chapter",
      "parentId": "root-planning",
      "childrenIds": [
        "product-vision",
        "mvp-scope",
