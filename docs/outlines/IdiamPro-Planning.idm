    "root-planning": {
      "id": "root-planning",
      "name": "IdiamPro Planning",
      "content": "<p><strong>Strategic Business Plan</strong></p><p>Comprehensive planning document covering market positioning, corporate structure, funding strategy, and path to profitability.</p><p></p><p><em>Last updated: January 2026</em></p>",
      "type": "root",
      "parentId": null,
      "childrenIds": [
        "exec-summary",
        "market-analysis",
