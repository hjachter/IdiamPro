    "prior-rebrand-secondbrainware": {
      "id": "prior-rebrand-secondbrainware",
      "name": "Rebrand website to SecondBrainWare",
      "content": "<ul><li><strong>Date completed:</strong> 2026-04-18</li><li><strong>Commit:</strong> <code>f2069df</code></li><li><strong>Files changed:</strong> 6</li><li><strong>Lines changed:</strong> +103 / -85</li><li><strong>Session duration:</strong> (prior session &mdash; not measured)</li></ul><p>Updated the public-facing site and all in-app documentation to use the SecondBrainWare brand while keeping the internal IdiamPro codebase identifier intact.</p>",
      "type": "document",
      "parentId": "prior-sessions",
      "childrenIds": [],
      "isExpanded": true,
      "prefix": "3"
    },
    "prior-second-brain-phase1": {
      "id": "prior-second-brain-phase1",
      "name": "Second Brain — Phase 1 (reserved outline, save action, Knowledge Chat)",
      "content": "<ul><li><strong>Date completed:</strong> 2026-04-17</li><li><strong>Commit:</strong> <code>c2fbe5a</code></li><li><strong>Files changed:</strong> 6</li><li><strong>Lines changed:</strong> +149 / -6</li><li><strong>Session duration:</strong> (prior session &mdash; not measured)</li></ul><p>The original Second Brain feature: a reserved outline that collects saved fragments, a Save action surfaced from any node, and a Knowledge Chat mode that queries the Second Brain corpus.</p>",
      "type": "document",
      "parentId": "prior-sessions",
      "childrenIds": [],
      "isExpanded": true,
      "prefix": "4"
    },
    "prior-gemma4-vision": {
      "id": "prior-gemma4-vision",
      "name": "Gemma 4 vision for user-supplied images",
      "content": "<ul><li><strong>Date completed:</strong> 2026-04-17</li><li><strong>Commit:</strong> <code>d0d5588</code></li><li><strong>Files changed:</strong> 2</li><li><strong>Lines changed:</strong> +158 / -15</li><li><strong>Session duration:</strong> (prior session &mdash; not measured)</li></ul><p>Local Gemma 4 vision support plus a describe-with-AI button so any image dropped into a node can be captioned locally.</p>",
      "type": "document",
