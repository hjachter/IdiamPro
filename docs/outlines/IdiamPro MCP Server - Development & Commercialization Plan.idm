      }
    },
    "2258dfd6-cad5-422a-bdd3-6a0f60049028": {
      "id": "2258dfd6-cad5-422a-bdd3-6a0f60049028",
      "name": "Beta Metrics (Weeks 1-4)",
      "content": "**Adoption:**\n- Beta signups: 50+\n- Active weekly users: 30+\n- Installation success: 80%+\n\n**Engagement:**\n- API calls per user: 100+/week\n- Tool usage distribution\n- Session duration/frequency\n\n**Quality:**\n- Critical bugs: < 10\n- Documentation rating: 4.5/5\n- Setup time: < 15 minutes",
      "type": "task",
      "parentId": "ca18f73a-6dde-4a3e-9b63-87fbc375f67f",
      "childrenIds": [],
      "prefix": "6.1",
      "metadata": {
        "createdAt": 1768038036243,
        "updatedAt": 1768038036243
      }
    },
    "bb33ff26-d003-4c13-87ce-da317e75d9ee": {
      "id": "bb33ff26-d003-4c13-87ce-da317e75d9ee",
      "name": "Revenue Metrics (Months 1-6)",
      "content": "**Conversion:**\n- Free signups: 500 (M1) \u2192 2,000 (M6)\n- Free-to-Premium: 5-10%\n- Premium-to-Pro: 10-15%\n- MRR: $500 (M1) \u2192 $5,000 (M6)\n\n**Churn:**\n- Monthly churn: < 10% (target: 5%)\n- Reactivation: > 20%",
      "type": "spreadsheet",
      "parentId": "ca18f73a-6dde-4a3e-9b63-87fbc375f67f",
      "childrenIds": [],
      "prefix": "6.2",
      "metadata": {
        "createdAt": 1768038036243,
        "updatedAt": 1768038036243
      }
    },
    "bf5b9d8e-7597-4996-a902-5943ff58480a": {
      "id": "bf5b9d8e-7597-4996-a902-5943ff58480a",
      "name": "Engagement Metrics",
      "content": "**API Usage:**\n- Total calls: 100k+/month (M6)\n- Average per user: 500-1,000/month\n\n**Retention:**\n- Day 7: 60%+\n- Day 30: 40%+\n- Day 90: 25%+\n\n**Power Users:**\n- 1,000+ calls/month: 10%+\n- Custom integrations: 5%+\n- Open source contributors: 2%+",
      "type": "spreadsheet",
      "parentId": "ca18f73a-6dde-4a3e-9b63-87fbc375f67f",
      "childrenIds": [],
      "prefix": "6.3",
      "metadata": {
