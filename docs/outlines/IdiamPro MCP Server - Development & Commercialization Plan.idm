        "3ce6cda2-ed3a-4467-83de-41a361540e46",
        "6f68576a-8b86-4257-9eee-dacdef63c314",
        "ca18f73a-6dde-4a3e-9b63-87fbc375f67f",
        "88f614a4-60c9-4da2-a498-9a50ed699889",
        "37c2360f-bf60-4ee8-9ca9-0c1df9b9fcba",
        "mcp-user-guide-section",
        "mcp-setup-guide",
        "7adf45bf-bf03-4296-996e-26494b9e5fd7",
        "f75c2fff-10f4-4fae-9051-1362cd9c4692"
