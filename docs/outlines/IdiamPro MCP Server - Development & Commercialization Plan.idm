      }
    },
    "d23334b4-0f78-4ae0-a724-dd36e930aca5": {
      "id": "d23334b4-0f78-4ae0-a724-dd36e930aca5",
      "name": "Community Metrics",
      "content": "- GitHub stars: 500+ (M6)\n- Contributors: 10+ (M6)\n- Discord members: 200+ (M6)\n- Blog visitors: 5,000+/month\n- Tutorial views: 10,000+ total\n\n---",
      "type": "spreadsheet",
