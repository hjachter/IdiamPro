    "insurance-types": {
      "id": "insurance-types",
      "name": "Required Coverage",
      "content": "<p><strong>General Liability:</strong> $1M coverage, $500-800/year - Bodily injury, property damage</p><p></p><p><strong>E&O (Professional Liability):</strong> $1M coverage, $1,000-3,000/year - Software failures, bad advice</p><p></p><p><strong>Cyber Liability:</strong> $1M coverage, $1,000-3,000/year - Data breaches, ransomware</p><p></p><p><strong>D&O (Directors & Officers):</strong> $1M coverage, $2,000-5,000/year - Investor protection (if funded)</p>",
      "type": "document",
      "parentId": "insurance",
      "childrenIds": [],
      "isCollapsed": false,
      "prefix": ""
    },
