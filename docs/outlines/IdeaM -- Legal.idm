    "license-audit": {
      "id": "license-audit",
      "name": "Third-Party Dependency Audit",
      "content": "<p><strong>Current Stack Licenses (All Safe for Commercial Use):</strong></p><p></p><p>Next.js - MIT | React - MIT | Electron - MIT | Tailwind CSS - MIT | Radix UI - MIT | Lucide Icons - ISC | Genkit - Apache 2.0 | pdf-parse - MIT</p><p></p><p><strong>Audit Results (1,400+ packages):</strong></p><p>MIT: 1017 | Apache-2.0: 212 | ISC: 92 | BSD variants: 49</p><p><span style=\"color: rgb(239, 68, 68);\">GPL-2.0: 1 | LGPL-3.0-or-later: 1</span> (Potential issues - review needed)</p>",
      "type": "chapter",
      "parentId": "root-legal",
      "childrenIds": [
        "license-tasks",
        "license-commands"
      ],
      "isCollapsed": true,
      "prefix": "4"
    },
