    "privacy-policy": {
      "id": "privacy-policy",
      "name": "Privacy Policy",
      "content": "<p><strong>Status: IMPLEMENTED</strong></p><p></p><p>Privacy policy page is live at <code>/privacy</code>. Covers:</p><ul><li><p>Local-only data storage</p></li><li><p>Third-party AI services (Google Gemini, OpenAI, AssemblyAI)</p></li><li><p>Microphone access for transcription</p></li><li><p>Children's privacy (COPPA)</p></li><li><p>Consent controls and revocation</p></li></ul><p></p><p>Linked from AI Consent Dialog and Settings page.</p>",
      "type": "chapter",
      "parentId": "root-legal",
      "childrenIds": [
        "privacy-disclosures",
        "privacy-gdpr",
