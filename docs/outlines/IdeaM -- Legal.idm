    "root-legal": {
      "id": "root-legal",
      "name": "IdeaM -- Legal",
      "content": "<p><strong>Legal Requirements &amp; Compliance Checklist</strong></p><p>Complete checklist for launching IdeaM as a commercial SaaS product.</p><p></p><p><strong>Legend:</strong></p><p>[CLAUDE] = Claude can do this task</p><p>[HUMAN] = Requires human action (payments, signatures, filings)</p><p>[LAWYER] = Requires attorney review</p><p></p><p><strong>Budget Summary:</strong> $7,250-19,500</p><p></p><p><em>Created: January 2025</em></p>",
      "type": "root",
      "parentId": null,
      "childrenIds": [
        "documents-for-lawyer",
        "terms-of-service",
        "privacy-policy",
        "license-audit",
        "api-compliance",
        "intellectual-property",
        "insurance",
        "additional-compliance",
        "timeline",
        "f763b764-8dfd-4d33-b364-815c674e82c6"
      ],
      "isCollapsed": false,
      "prefix": ""
    },
