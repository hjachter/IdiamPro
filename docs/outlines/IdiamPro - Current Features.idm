    },
    "e7d178d7-6be2-41e0-8a7d-429400825a12": {
      "id": "e7d178d7-6be2-41e0-8a7d-429400825a12",
      "name": "Educational (Premium)",
      "content": "<p>Courses, tutorials. Collapsible modules with numbered lessons, learning outcomes, progress indicators.</p>",
