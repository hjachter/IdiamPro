      "parentId": "4f1ab90d-9f1b-4ee6-badb-7ce8804f37a7",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "11.6.",
      "metadata": {}
    },
    "34f53a54-dc0c-49bf-8fe4-41b2ec2b6a4f": {
      "id": "34f53a54-dc0c-49bf-8fe4-41b2ec2b6a4f",
      "name": "Blog (Premium)",
      "content": "<p>Articles, news. Featured hero post, topic categories, newsletter signup, archive list.</p>",
      "type": "document",
      "parentId": "4f1ab90d-9f1b-4ee6-badb-7ce8804f37a7",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "11.7.",
      "metadata": {}
    },
    "ca4ccd71-1357-4c78-828e-c87047222d94": {
      "id": "ca4ccd71-1357-4c78-828e-c87047222d94",
      "name": "Personal (Premium)",
      "content": "<p>Resumes, CVs. Experience timeline, skills grid with proficiency bars, accomplishments stats.</p>",
