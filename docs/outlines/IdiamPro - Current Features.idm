      "id": "0f469ad1-812f-4f6b-8708-8463e5f7d20d",
      "name": "Informational",
      "content": "<p>Company pages, product info. Apple.com-inspired design with whitespace, highlights, feature strips.</p>",
      "type": "document",
      "parentId": "4f1ab90d-9f1b-4ee6-badb-7ce8804f37a7",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "11.2.",
      "metadata": {}
    },
