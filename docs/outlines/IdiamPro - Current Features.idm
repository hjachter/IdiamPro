      "id": "098bac1f-9e36-48a5-b1f7-41f8751c0152",
      "name": "Marketing",
      "content": "<p>Landing pages, product launches. Hero with stats, benefits grid, chapter previews, FAQ section, CTA.</p>",
      "type": "document",
      "parentId": "4f1ab90d-9f1b-4ee6-badb-7ce8804f37a7",
      "childrenIds": [],
      "isCollapsed": true,
