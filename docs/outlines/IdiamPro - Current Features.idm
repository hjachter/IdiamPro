    },
    "dd2e511e-a401-4a5a-a2ce-45128dbb92bb": {
      "id": "dd2e511e-a401-4a5a-a2ce-45128dbb92bb",
      "name": "Portfolio (Premium)",
      "content": "<p>Creative work, case studies. Filterable project grid, hover effects, process steps, contact CTA.</p>",
