      "id": "45a5c7c7-f8dc-4ddf-97e2-f0caab37672d",
      "name": "Set Color",
      "content": "<p>8 colors: red, orange, yellow, green, blue, purple, pink, default. Visual color strip on node.</p>",
      "type": "document",
      "parentId": "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "14.4.",
      "metadata": {}
    },
    "78dea869-7049-48df-9e8f-0bdfb8077d9c": {
      "id": "78dea869-7049-48df-9e8f-0bdfb8077d9c",
      "name": "Manage Tags",
      "content": "<p>Open tag manager dialog. Add/remove tags with search and autocomplete.</p>",
      "type": "document",
      "parentId": "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "14.5.",
      "metadata": {}
    },
    "862b1922-7efe-4965-a0d3-1c156d019736": {
      "id": "862b1922-7efe-4965-a0d3-1c156d019736",
      "name": "Delete Node",
      "content": "<p>Delete with confirmation dialog (configurable in settings).</p>",
      "type": "document",
      "parentId": "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "14.6.",
      "metadata": {}
    },
    "7988e784-fb00-44b8-8fbe-04e5f5713a18": {
      "id": "7988e784-fb00-44b8-8fbe-04e5f5713a18",
      "name": "Outline Management",
      "content": "<p>Create, organize, and manage your outline files.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "1e14d2d0-2eea-44cd-aa11-9a5102e762c1",
        "e684c1df-5f40-4200-a781-b04f0e93f9ba",
        "deaa1e64-76e0-47e7-aba2-49d47749a902",
