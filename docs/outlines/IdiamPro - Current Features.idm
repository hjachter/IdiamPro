      "id": "ea93bb72-cc2b-4f87-8850-4bee9f7d83e5",
      "name": "Documentation",
      "content": "<p>User guides, API docs. Sidebar navigation, breadcrumbs, quick-start links, prev/next navigation.</p>",
      "type": "document",
      "parentId": "4f1ab90d-9f1b-4ee6-badb-7ce8804f37a7",
      "childrenIds": [],
      "isCollapsed": true,
