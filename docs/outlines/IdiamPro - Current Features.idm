    },
    "fca7ff30-3125-4c29-8bfb-b166fa68c6f5": {
      "id": "fca7ff30-3125-4c29-8bfb-b166fa68c6f5",
      "name": "User Guide Outline",
      "content": "<p>Built-in comprehensive guide covering all features. Read-only. Refreshable via command palette.</p>",
      "type": "document",
      "parentId": "09347361-9110-48b5-9892-8b716627b2eb",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "19.1.",
      "metadata": {}
    },
    "5cf18681-04b5-40b4-8dd4-7690516d30f2": {
      "id": "5cf18681-04b5-40b4-8dd4-7690516d30f2",
      "name": "Help Chat",
      "content": "<p>AI assistant for feature questions. CircleHelp icon in toolbar. Streaming responses with full IdiamPro context.</p>",
      "type": "document",
      "parentId": "09347361-9110-48b5-9892-8b716627b2eb",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "19.2.",
      "metadata": {}
    },
    "7e361f73-649e-4a67-ad1a-46dbf0d98ee9": {
      "id": "7e361f73-649e-4a67-ad1a-46dbf0d98ee9",
      "name": "Keyboard Shortcuts Dialog",
      "content": "<p>Press ? key to view all shortcuts in a formatted dialog.</p>",
      "type": "document",
      "parentId": "09347361-9110-48b5-9892-8b716627b2eb",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "19.3.",
      "metadata": {}
    },
    "b23d1539-ab10-4af2-997d-0d5a819912b7": {
      "id": "b23d1539-ab10-4af2-997d-0d5a819912b7",
      "name": "Tooltips",
      "content": "<p>Hover tips on all toolbar buttons describing their function.</p>",
      "type": "document",
      "parentId": "09347361-9110-48b5-9892-8b716627b2eb",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "19.4.",
      "metadata": {}
    },
    "bdf5df8c-17a6-441b-ab3a-39ba989c1da0": {
      "id": "bdf5df8c-17a6-441b-ab3a-39ba989c1da0",
      "name": "Subscription Plans",
      "content": "<p>Tiered access to features.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "ec1f02de-9e8c-453d-b464-d10469c05dab",
        "69ae644f-b900-41e4-871e-8d1866d58525",
        "fd672726-3701-418c-b762-cf059091ff8b"
      ],
      "isCollapsed": true,
      "prefix": "20.",
      "metadata": {}
    },
    "ec1f02de-9e8c-453d-b464-d10469c05dab": {
      "id": "ec1f02de-9e8c-453d-b464-d10469c05dab",
      "name": "Free Plan",
      "content": "<p>Generate Outline: 10/month. Expand Content: 50/month. Research: 3 sources. All basic export formats. 3 website templates (Marketing, Informational, Documentation).</p>",
      "type": "document",
      "parentId": "bdf5df8c-17a6-441b-ab3a-39ba989c1da0",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "20.1.",
      "metadata": {}
    },
    "69ae644f-b900-41e4-871e-8d1866d58525": {
      "id": "69ae644f-b900-41e4-871e-8d1866d58525",
      "name": "Premium Plan",
      "content": "<p>Generate Outline: 100/month. Expand Content: 500/month. Research: 50+ sources. All 8 website templates. Podcast generation. Knowledge Chat. All features unlocked.</p>",
      "type": "document",
      "parentId": "bdf5df8c-17a6-441b-ab3a-39ba989c1da0",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "20.2.",
      "metadata": {}
    },
    "fd672726-3701-418c-b762-cf059091ff8b": {
      "id": "fd672726-3701-418c-b762-cf059091ff8b",
      "name": "Beta Note",
      "content": "<p>During beta, all premium features are available to all users for testing.</p>",
      "type": "document",
      "parentId": "bdf5df8c-17a6-441b-ab3a-39ba989c1da0",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "20.3.",
      "metadata": {}
    },
    "feat-ai-consent": {
      "id": "feat-ai-consent",
      "name": "AI Data Consent",
      "content": "<p>Apple-compliant consent dialog shown before first AI feature use. Explains which third-party services process data (Google Gemini, OpenAI, AssemblyAI). Two-step decline flow warns about feature loss. Manageable in Settings \u2192 Data &amp; Privacy.</p>",
      "childrenIds": [],
      "isExpanded": false
    },
    "feat-privacy-policy": {
      "id": "feat-privacy-policy",
      "name": "Privacy Policy Page",
      "content": "<p>Accessible at /privacy. Covers data storage (local only), third-party AI services, microphone access, children's privacy, and consent controls.</p>",
      "childrenIds": [],
      "isExpanded": false
    }
  },
