    },
    "7944dd55-f0bf-421a-b8a6-599828569dc7": {
      "id": "7944dd55-f0bf-421a-b8a6-599828569dc7",
      "name": "Event (Premium)",
      "content": "<p>Conferences, webinars. Hero with date/location, schedule timeline, speaker cards, registration CTA.</p>",
