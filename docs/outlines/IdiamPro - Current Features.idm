    },
    "84e35b0f-52ca-4fbe-98ca-d8995734c077": {
      "id": "84e35b0f-52ca-4fbe-98ca-d8995734c077",
      "name": "Customization",
      "content": "<p>Content depth (Overview/Standard/Comprehensive), color scheme (Light/Dark/Auto), custom colors (primary/secondary/background/text), title, tagline, CTA button text.</p>",
      "type": "chapter",
      "parentId": "4f1ab90d-9f1b-4ee6-badb-7ce8804f37a7",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "11.9.",
      "metadata": {}
    },
    "e46a7bf4-91da-416a-91f3-43a4bd465c13": {
      "id": "e46a7bf4-91da-416a-91f3-43a4bd465c13",
      "name": "Podcast Generation (Premium)",
      "content": "<p>AI-generated audio podcasts from outline content.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "90a4660d-256b-407c-896d-6ee300caf47d",
        "54af51f0-f04a-41c3-b78f-445e7cbf0858",
        "2babd286-ad18-4a0b-b18c-52fcfa475304"
      ],
      "isCollapsed": true,
      "prefix": "12.",
      "metadata": {}
    },
    "90a4660d-256b-407c-896d-6ee300caf47d": {
      "id": "90a4660d-256b-407c-896d-6ee300caf47d",
      "name": "Podcast Styles",
      "content": "<p>Two-Host Discussion, Single Narrator, Interview, Debate.</p>",
      "type": "document",
      "parentId": "e46a7bf4-91da-416a-91f3-43a4bd465c13",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "12.1.",
      "metadata": {}
    },
    "54af51f0-f04a-41c3-b78f-445e7cbf0858": {
      "id": "54af51f0-f04a-41c3-b78f-445e7cbf0858",
      "name": "Voice Selection",
      "content": "<p>6 voices: Alloy (neutral), Echo (male), Fable (expressive), Nova (female), Onyx (deep male), Shimmer (warm female). Standard or HD quality.</p>",
      "type": "document",
      "parentId": "e46a7bf4-91da-416a-91f3-43a4bd465c13",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "12.2.",
      "metadata": {}
    },
    "2babd286-ad18-4a0b-b18c-52fcfa475304": {
      "id": "2babd286-ad18-4a0b-b18c-52fcfa475304",
      "name": "Length Options",
      "content": "<p>Brief (2-3 min), Standard (5-8 min), Detailed (10-15 min). Script preview before synthesis. Audio preview in-app. Download as MP3.</p>",
      "type": "document",
      "parentId": "e46a7bf4-91da-416a-91f3-43a4bd465c13",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "12.3.",
      "metadata": {}
    },
    "c263b77a-03b1-47d8-b909-64f2ee69f9ba": {
      "id": "c263b77a-03b1-47d8-b909-64f2ee69f9ba",
      "name": "Keyboard Shortcuts",
      "content": "<p>Comprehensive keyboard shortcuts for efficient workflow. Press ? to view all shortcuts.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "d6ccce71-9155-492e-bae9-d508d12002bd",
        "194d4535-510a-4d23-a3c7-73c597ec7e64",
        "25755997-6499-43ec-aa5c-ad6dcc4281fe",
        "13fe9582-53e5-41c8-82f0-405acda286f5",
        "78573412-402c-4d0b-973c-8753b5105431"
      ],
      "isCollapsed": true,
      "prefix": "13.",
      "metadata": {}
    },
    "d6ccce71-9155-492e-bae9-d508d12002bd": {
      "id": "d6ccce71-9155-492e-bae9-d508d12002bd",
      "name": "General",
      "content": "<p>Cmd+K: Command palette. Ctrl+F: Search outline. Cmd+Shift+F: Focus mode (Esc to exit). ?: Show shortcuts.</p>",
      "type": "document",
      "parentId": "c263b77a-03b1-47d8-b909-64f2ee69f9ba",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "13.1.",
      "metadata": {}
    },
    "194d4535-510a-4d23-a3c7-73c597ec7e64": {
      "id": "194d4535-510a-4d23-a3c7-73c597ec7e64",
      "name": "Navigation",
      "content": "<p>Arrow Up/Down: Navigate nodes. Arrow Left/Right: Collapse/expand. Enter: Edit selected node.</p>",
      "type": "document",
      "parentId": "c263b77a-03b1-47d8-b909-64f2ee69f9ba",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "13.2.",
      "metadata": {}
    },
    "25755997-6499-43ec-aa5c-ad6dcc4281fe": {
      "id": "25755997-6499-43ec-aa5c-ad6dcc4281fe",
      "name": "Editing",
      "content": "<p>Cmd+N: New sibling node. Cmd+D: Duplicate node. Delete/Backspace: Delete with confirmation. Cmd+Backspace: Delete without confirmation. Tab: Indent. Shift+Tab: Outdent.</p>",
      "type": "document",
      "parentId": "c263b77a-03b1-47d8-b909-64f2ee69f9ba",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "13.3.",
      "metadata": {}
    },
    "13fe9582-53e5-41c8-82f0-405acda286f5": {
      "id": "13fe9582-53e5-41c8-82f0-405acda286f5",
      "name": "Clipboard",
      "content": "<p>Cmd+C: Copy subtree. Cmd+X: Cut subtree. Cmd+V: Paste subtree.</p>",
      "type": "document",
      "parentId": "c263b77a-03b1-47d8-b909-64f2ee69f9ba",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "13.4.",
      "metadata": {}
    },
    "78573412-402c-4d0b-973c-8753b5105431": {
      "id": "78573412-402c-4d0b-973c-8753b5105431",
      "name": "Formatting",
      "content": "<p>Cmd+B: Bold. Cmd+I: Italic. Cmd+Z: Undo. Cmd+Shift+Z: Redo.</p>",
      "type": "document",
      "parentId": "c263b77a-03b1-47d8-b909-64f2ee69f9ba",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "13.5.",
      "metadata": {}
    },
    "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c": {
      "id": "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c",
      "name": "Context Menu",
      "content": "<p>Right-click (macOS) or long-press (iOS) any node for these actions.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "2dc087cb-6b6e-4d56-8b66-5401100f4df6",
