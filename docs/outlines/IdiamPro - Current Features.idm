      "parentId": "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "14.2.",
      "metadata": {}
    },
    "8f53ffbf-6ebd-4aeb-a665-39d586d0659b": {
      "id": "8f53ffbf-6ebd-4aeb-a665-39d586d0659b",
      "name": "Set Type",
      "content": "<p>Change node type: chapter, document, note, task, link, code, quote, date, canvas.</p>",
      "type": "document",
      "parentId": "a59619ec-8f4d-4bca-ae7c-0bc3be0a776c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "14.3.",
      "metadata": {}
    },
