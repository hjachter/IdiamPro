    "66587491-ee3f-4abd-bf70-78afb0558b8c": {
      "id": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "name": "Node Metadata & Properties",
      "content": "<p>Every node carries rich metadata beyond its name and content.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "ff2c26eb-387d-44c1-98a3-9846ac47ab7a",
        "f03d580d-c8fc-4409-8c08-e6a009b697e7",
        "0e09829f-a189-40c6-9571-11ebea45a5d7",
        "3f382f0e-2730-4a4b-b578-a42325d0a966",
        "eba58fb2-7a94-4443-a7cf-f6d982518c86",
        "a8147783-ff92-46f4-b1bf-37724e1b81cf"
      ],
      "isCollapsed": true,
      "prefix": "2.",
      "metadata": {}
    },
    "ff2c26eb-387d-44c1-98a3-9846ac47ab7a": {
      "id": "ff2c26eb-387d-44c1-98a3-9846ac47ab7a",
      "name": "Node Colors",
      "content": "<p>8 color options: default, red, orange, yellow, green, blue, purple, pink. Applied via context menu or multi-select toolbar. Shown as colored left border strip on nodes.</p>",
      "type": "document",
      "parentId": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "2.1.",
      "metadata": {}
    },
    "f03d580d-c8fc-4409-8c08-e6a009b697e7": {
      "id": "f03d580d-c8fc-4409-8c08-e6a009b697e7",
      "name": "Tags",
      "content": "<p>Multi-tag system for organization. Add/remove via Tag Manager dialog. Tags shown as badges on nodes. Filter outlines by tags.</p>",
      "type": "document",
      "parentId": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "2.2.",
      "metadata": {}
    },
    "0e09829f-a189-40c6-9571-11ebea45a5d7": {
      "id": "0e09829f-a189-40c6-9571-11ebea45a5d7",
      "name": "Pinning",
      "content": "<p>Pin nodes to top of their sibling list. Star icon indicator.</p>",
      "type": "document",
      "parentId": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "2.3.",
      "metadata": {}
    },
    "3f382f0e-2730-4a4b-b578-a42325d0a966": {
      "id": "3f382f0e-2730-4a4b-b578-a42325d0a966",
      "name": "Task Completion",
      "content": "<p>Toggle checkbox for task nodes. Completed tasks shown with checkmark and strikethrough styling.</p>",
      "type": "document",
      "parentId": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "2.4.",
      "metadata": {}
    },
    "eba58fb2-7a94-4443-a7cf-f6d982518c86": {
      "id": "eba58fb2-7a94-4443-a7cf-f6d982518c86",
      "name": "Automatic Timestamps",
      "content": "<p>Created and updated timestamps tracked automatically for every node.</p>",
      "type": "document",
      "parentId": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "2.5.",
      "metadata": {}
    },
    "a8147783-ff92-46f4-b1bf-37724e1b81cf": {
      "id": "a8147783-ff92-46f4-b1bf-37724e1b81cf",
      "name": "Hierarchical Numbering",
      "content": "<p>Automatic prefix numbering (1, 1.1, 1.1.2, etc.) calculated from tree position.</p>",
      "type": "document",
      "parentId": "66587491-ee3f-4abd-bf70-78afb0558b8c",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "2.6.",
      "metadata": {}
    },
    "847ff87f-3148-4f31-8c5d-06be8330b015": {
      "id": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "name": "Core Outlining Features",
      "content": "<p>The fundamental outlining operations that make IdiamPro a professional tool.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "f2bbf961-5930-4e27-8972-be07835c6bf6",
        "a955d14a-0a77-4f17-9d50-af7c87e2c8f6",
        "f100728d-a8fa-45d5-be08-0b0620fa6cb8",
        "422f2816-c7e0-4b8c-ad63-2dfec8545527",
        "8db7d6ae-84bd-4f1f-ab3e-784ac74479f1",
        "d8e58d72-4557-4244-a14f-424dd8e09cc9",
        "a389e42e-c4d4-433e-a9af-7d71f64e3f2b"
      ],
      "isCollapsed": true,
      "prefix": "3.",
      "metadata": {}
    },
    "f2bbf961-5930-4e27-8972-be07835c6bf6": {
      "id": "f2bbf961-5930-4e27-8972-be07835c6bf6",
      "name": "Hierarchical Tree Structure",
      "content": "<p>Unlimited nesting depth. Parent-child relationships with flat NodeMap storage for performance.</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.1.",
      "metadata": {}
    },
    "a955d14a-0a77-4f17-9d50-af7c87e2c8f6": {
      "id": "a955d14a-0a77-4f17-9d50-af7c87e2c8f6",
      "name": "Drag & Drop",
      "content": "<p>Reorganize nodes by dragging. Drop before, after, or inside target nodes. Visual feedback with drop zone highlighting. Cannot drop onto descendants.</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.2.",
      "metadata": {}
    },
    "f100728d-a8fa-45d5-be08-0b0620fa6cb8": {
      "id": "f100728d-a8fa-45d5-be08-0b0620fa6cb8",
      "name": "Indent / Outdent",
      "content": "<p>Tab to indent (make child of previous sibling). Shift+Tab to outdent (move up one level). Also available via iOS swipe gestures.</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.3.",
      "metadata": {}
    },
    "422f2816-c7e0-4b8c-ad63-2dfec8545527": {
      "id": "422f2816-c7e0-4b8c-ad63-2dfec8545527",
      "name": "Collapse / Expand",
      "content": "<p>Toggle node visibility with chevron click. Expand All / Collapse All buttons. Arrow keys expand/collapse during keyboard navigation.</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.4.",
      "metadata": {}
    },
    "8db7d6ae-84bd-4f1f-ab3e-784ac74479f1": {
      "id": "8db7d6ae-84bd-4f1f-ab3e-784ac74479f1",
      "name": "Focus Mode",
      "content": "<p>Isolate a subtree to full screen with Cmd+Shift+F. Press Esc to exit. Shows only the selected node and its descendants.</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.5.",
      "metadata": {}
    },
    "d8e58d72-4557-4244-a14f-424dd8e09cc9": {
      "id": "d8e58d72-4557-4244-a14f-424dd8e09cc9",
      "name": "Multi-Select",
      "content": "<p>Cmd/Ctrl+Click to select multiple nodes. Shift+Click for range selection. Floating toolbar appears with bulk operations: delete, change color, add tags, indent/outdent.</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.6.",
      "metadata": {}
    },
    "a389e42e-c4d4-433e-a9af-7d71f64e3f2b": {
      "id": "a389e42e-c4d4-433e-a9af-7d71f64e3f2b",
      "name": "Node Operations",
      "content": "<p>Create sibling (Enter), duplicate (Cmd+D), delete (Backspace/Delete), rename (double-click or tap selected). Copy/Cut/Paste entire subtrees (Cmd+C/X/V).</p>",
      "type": "document",
      "parentId": "847ff87f-3148-4f31-8c5d-06be8330b015",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "3.7.",
      "metadata": {}
    },
    "a19474f3-3a9c-4e28-a7c4-d0d2143d3d56": {
      "id": "a19474f3-3a9c-4e28-a7c4-d0d2143d3d56",
      "name": "Search & Navigation",
      "content": "<p>Powerful search across node names and content.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "9f2bead2-bf61-434a-9100-fd8055dc5ea4",
        "94bb943b-5b85-4871-8a2b-64617a863b86",
        "c503bc67-21bc-488d-afbd-b0edea0e9951",
        "6db5e34d-b8e6-489e-ac66-14de24ba5f88"
      ],
      "isCollapsed": true,
      "prefix": "4.",
      "metadata": {}
    },
    "9f2bead2-bf61-434a-9100-fd8055dc5ea4": {
      "id": "9f2bead2-bf61-434a-9100-fd8055dc5ea4",
      "name": "Outline Search",
      "content": "<p>Full-text search across outline nodes with Ctrl/Cmd+F.</p><p></p><p><strong>Features:</strong></p><ul><li><p>Search current outline or all outlines (globe toggle)</p></li><li><p>Filter by node names (T icon) or content (paragraph icon) \u2014 toggle independently</p></li><li><p>Real-time results with 150ms debounce</p></li><li><p>Navigate matches with Enter/Shift+Enter or arrow buttons</p></li><li><p>Match counter shows current position</p></li><li><p>Large outline optimization: outlines with 5000+ nodes search leaf nodes only</p></li></ul>",
      "type": "document",
      "parentId": "a19474f3-3a9c-4e28-a7c4-d0d2143d3d56",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "4.1.",
      "metadata": {}
    },
    "94bb943b-5b85-4871-8a2b-64617a863b86": {
      "id": "94bb943b-5b85-4871-8a2b-64617a863b86",
      "name": "Search Highlighting",
      "content": "<p>Matching text highlighted in yellow. Navigate between matches with up/down arrows.</p>",
      "type": "document",
      "parentId": "a19474f3-3a9c-4e28-a7c4-d0d2143d3d56",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "4.2.",
      "metadata": {}
    },
    "c503bc67-21bc-488d-afbd-b0edea0e9951": {
      "id": "c503bc67-21bc-488d-afbd-b0edea0e9951",
      "name": "Command Palette",
      "content": "<p>Cmd+K opens command palette. Quick access to all commands: new node, new outline, templates, duplicate, delete, search, focus mode, collapse/expand all, export, import, shortcuts.</p>",
      "type": "document",
      "parentId": "a19474f3-3a9c-4e28-a7c4-d0d2143d3d56",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "4.3.",
      "metadata": {}
    },
    "6db5e34d-b8e6-489e-ac66-14de24ba5f88": {
      "id": "6db5e34d-b8e6-489e-ac66-14de24ba5f88",
      "name": "Keyboard Navigation",
      "content": "<p>Arrow Up/Down to navigate nodes. Arrow Left/Right to collapse/expand. Enter to edit. Full keyboard-driven workflow.</p>",
      "type": "document",
      "parentId": "a19474f3-3a9c-4e28-a7c4-d0d2143d3d56",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "4.4.",
      "metadata": {}
    },
    "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160": {
      "id": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "name": "Content Editor (TipTap)",
      "content": "<p>Rich text editor powered by TipTap with extensive formatting capabilities.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "eec9b09a-53fc-4a0e-83a6-68a977ca0388",
        "3081abf5-9c49-4c66-9e2b-8e3f3a21d237",
        "176daeb8-3d43-43a7-a604-5b6c827e31bb",
        "b6975d11-1865-428d-85b5-b4674b36405a",
        "07a1cc61-3674-4802-922d-d5e02d6621dd",
        "439edea3-5239-47f9-a3a1-d123a6f93c4a",
        "25c0d2af-ac11-4496-91e3-f87e4ed63f5f"
      ],
      "isCollapsed": true,
      "prefix": "5.",
      "metadata": {}
    },
    "eec9b09a-53fc-4a0e-83a6-68a977ca0388": {
      "id": "eec9b09a-53fc-4a0e-83a6-68a977ca0388",
      "name": "Text Formatting",
      "content": "<p>Bold (Cmd+B), Italic (Cmd+I), Strikethrough. Headings H1-H3. Blockquotes. Undo/Redo (Cmd+Z / Cmd+Shift+Z).</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.1.",
      "metadata": {}
    },
    "3081abf5-9c49-4c66-9e2b-8e3f3a21d237": {
      "id": "3081abf5-9c49-4c66-9e2b-8e3f3a21d237",
      "name": "Lists",
      "content": "<p>Unordered lists, ordered lists, and checklists with toggle completion.</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.2.",
      "metadata": {}
    },
    "176daeb8-3d43-43a7-a604-5b6c827e31bb": {
      "id": "176daeb8-3d43-43a7-a604-5b6c827e31bb",
      "name": "Code Blocks",
      "content": "<p>Syntax-highlighted code blocks with language selection.</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.3.",
      "metadata": {}
    },
    "b6975d11-1865-428d-85b5-b4674b36405a": {
      "id": "b6975d11-1865-428d-85b5-b4674b36405a",
      "name": "Links",
      "content": "<p>Clickable hyperlinks. Auto-detection: pasting URLs automatically creates links.</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.4.",
      "metadata": {}
    },
    "07a1cc61-3674-4802-922d-d5e02d6621dd": {
      "id": "07a1cc61-3674-4802-922d-d5e02d6621dd",
      "name": "Images",
      "content": "<p>Inline image embedding. Drag-and-drop images into content. Paste from clipboard (Cmd+V).</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.5.",
      "metadata": {}
    },
    "439edea3-5239-47f9-a3a1-d123a6f93c4a": {
      "id": "439edea3-5239-47f9-a3a1-d123a6f93c4a",
      "name": "Tables",
      "content": "<p>Markdown table support. Auto-detection of tabular data and ASCII tables with monospace formatting.</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.6.",
      "metadata": {}
    },
    "25c0d2af-ac11-4496-91e3-f87e4ed63f5f": {
      "id": "25c0d2af-ac11-4496-91e3-f87e4ed63f5f",
      "name": "Embeds",
      "content": "<p>Google Docs, Sheets, Slides, Maps embedding via URL paste. YouTube video embeds. Mermaid diagram rendering in code blocks.</p>",
      "type": "document",
      "parentId": "5a9272e2-c6cc-4398-ba1b-f6db5b3e8160",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "5.7.",
      "metadata": {}
    },
    "6363ff46-2210-47de-89f0-d5dd9dde1e60": {
      "id": "6363ff46-2210-47de-89f0-d5dd9dde1e60",
      "name": "Speech-to-Text & Recording",
      "content": "<p>Record and transcribe speech directly in the content pane.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "f6108113-46b6-4d73-b677-4defb6118021",
        "e5dccf6b-c73f-4aa3-80aa-79ef86433db5"
      ],
      "isCollapsed": true,
      "prefix": "6.",
      "metadata": {}
    },
    "f6108113-46b6-4d73-b677-4defb6118021": {
      "id": "f6108113-46b6-4d73-b677-4defb6118021",
      "name": "Speech Recognition",
      "content": "<p>Click microphone button to record. Uses Web Speech API for local transcription. Text appears in content pane as you speak.</p>",
      "type": "document",
      "parentId": "6363ff46-2210-47de-89f0-d5dd9dde1e60",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "6.1.",
      "metadata": {}
    },
    "e5dccf6b-c73f-4aa3-80aa-79ef86433db5": {
      "id": "e5dccf6b-c73f-4aa3-80aa-79ef86433db5",
      "name": "Audio Recording",
      "content": "<p>Record conversations and audio. Diarized transcripts with speaker identification and labels. Playback before processing.</p>",
      "type": "document",
      "parentId": "6363ff46-2210-47de-89f0-d5dd9dde1e60",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "6.2.",
      "metadata": {}
    },
    "226bf1b4-4a1b-4d14-aa4c-f6e5a7ffb270": {
      "id": "226bf1b4-4a1b-4d14-aa4c-f6e5a7ffb270",
      "name": "File Import & Handling",
      "content": "<p>Import files of any type directly into outlines.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "7906472e-c000-48d2-9d65-01d0d0b09cd3",
        "d08761f7-878c-4ba0-948c-1b7036ae0bfb",
        "665f57fc-ad58-43a4-85c3-2f91f800d577",
        "5421dfc5-919d-4e0f-98cd-716eef2fa403"
      ],
      "isCollapsed": true,
      "prefix": "7.",
      "metadata": {}
    },
    "7906472e-c000-48d2-9d65-01d0d0b09cd3": {
      "id": "7906472e-c000-48d2-9d65-01d0d0b09cd3",
      "name": "Import Button",
      "content": "<p>Paperclip icon in content pane toolbar. Also accessible via dropdown menu > Import Outline.</p>",
      "type": "document",
      "parentId": "226bf1b4-4a1b-4d14-aa4c-f6e5a7ffb270",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "7.1.",
      "metadata": {}
    },
    "d08761f7-878c-4ba0-948c-1b7036ae0bfb": {
      "id": "d08761f7-878c-4ba0-948c-1b7036ae0bfb",
      "name": "Auto-Detection",
      "content": "<p>File format auto-detected from extension. Supports: Markdown (.md), Plain Text (.txt), OPML (.opml), JSON/IDM (.json/.idm).</p>",
      "type": "document",
      "parentId": "226bf1b4-4a1b-4d14-aa4c-f6e5a7ffb270",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "7.2.",
      "metadata": {}
    },
    "665f57fc-ad58-43a4-85c3-2f91f800d577": {
      "id": "665f57fc-ad58-43a4-85c3-2f91f800d577",
      "name": "Media Handling",
      "content": "<p>Images embed inline. Videos embed with player controls. Audio files embed with native player. PDFs offer text extraction or link insertion dialog.</p>",
      "type": "document",
      "parentId": "226bf1b4-4a1b-4d14-aa4c-f6e5a7ffb270",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "7.3.",
      "metadata": {}
    },
    "5421dfc5-919d-4e0f-98cd-716eef2fa403": {
      "id": "5421dfc5-919d-4e0f-98cd-716eef2fa403",
      "name": "Drag-and-Drop Files",
      "content": "<p>Drop files directly into content pane to import. Other file types insert as download links.</p>",
      "type": "document",
      "parentId": "226bf1b4-4a1b-4d14-aa4c-f6e5a7ffb270",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "7.4.",
      "metadata": {}
    },
    "99e64397-d0fd-442e-af2c-c9be677aff26": {
      "id": "99e64397-d0fd-442e-af2c-c9be677aff26",
      "name": "AI Features",
      "content": "<p>Comprehensive AI capabilities powered by Gemini (cloud) or Ollama with Gemma 4 (local).</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "2a7fd1df-b812-44a6-bbef-05d915b15d13",
        "3ad2801b-8e79-4ccf-b46d-8f0744bacc37",
        "c72f7bca-b7b7-4d68-a3d9-2288a15c18c2",
        "63cdae02-1798-4608-a55f-b05c93abbce3",
        "7264c8d7-3b2c-4cca-81cf-5ad6df5198d4",
        "feat-ai-consent",
        "feat-privacy-policy"
      ],
      "isCollapsed": true,
      "prefix": "8.",
      "metadata": {}
    },
    "2a7fd1df-b812-44a6-bbef-05d915b15d13": {
      "id": "2a7fd1df-b812-44a6-bbef-05d915b15d13",
      "name": "Outline Generation",
      "content": "<p>AI creates full outline structure from a text prompt. Three depth modes: Quick (fast), Standard (balanced), Deep (thorough). Free: 10/month. Premium: 100/month.</p>",
      "type": "chapter",
      "parentId": "99e64397-d0fd-442e-af2c-c9be677aff26",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "8.1.",
      "metadata": {}
    },
    "3ad2801b-8e79-4ccf-b46d-8f0744bacc37": {
      "id": "3ad2801b-8e79-4ccf-b46d-8f0744bacc37",
      "name": "Content Expansion",
      "content": "<p>AI expands selected node content with contextual awareness. Uses ancestor path and existing content. Create Content for Descendants generates for all children at once. Free: 50/month. Premium: 500/month.</p>",
      "type": "document",
      "parentId": "99e64397-d0fd-442e-af2c-c9be677aff26",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "8.2.",
      "metadata": {}
    },
    "c72f7bca-b7b7-4d68-a3d9-2288a15c18c2": {
      "id": "c72f7bca-b7b7-4d68-a3d9-2288a15c18c2",
      "name": "Research & Import (Premium)",
      "content": "<p>Multi-source import and synthesis. Sources: YouTube, PDFs, web pages, images, docs, audio, video, outlines, recordings, text. Free: 3 sources. Premium: 50+ sources.</p>",
      "type": "chapter",
      "parentId": "99e64397-d0fd-442e-af2c-c9be677aff26",
      "childrenIds": [
        "a58d0d63-c0d2-4064-a0e3-248949270657",
        "55dc2060-a726-43ab-88ab-a29653ea0a06"
      ],
      "isCollapsed": true,
      "prefix": "8.3.",
      "metadata": {}
    },
    "a58d0d63-c0d2-4064-a0e3-248949270657": {
      "id": "a58d0d63-c0d2-4064-a0e3-248949270657",
      "name": "Merge Strategies",
      "content": "<p>Synthesize (deep merge finding connections), Separate (distinct sections), Architecture (relationships described). Detail levels: Overview (3 levels), Standard (4 levels), Comprehensive (5-6 levels).</p>",
      "type": "document",
      "parentId": "c72f7bca-b7b7-4d68-a3d9-2288a15c18c2",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "8.3.1.",
      "metadata": {}
    },
    "55dc2060-a726-43ab-88ab-a29653ea0a06": {
      "id": "55dc2060-a726-43ab-88ab-a29653ea0a06",
      "name": "Pending Recovery",
      "content": "<p>If import times out, result saved for recovery on next launch. Unmerge button (orange circular arrow) restores pre-merge state.</p>",
      "type": "document",
      "parentId": "c72f7bca-b7b7-4d68-a3d9-2288a15c18c2",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "8.3.2.",
      "metadata": {}
    },
    "63cdae02-1798-4608-a55f-b05c93abbce3": {
      "id": "63cdae02-1798-4608-a55f-b05c93abbce3",
      "name": "Knowledge Chat (Premium)",
      "content": "<p>Query your outlines using natural language. Blue brain icon in toolbar.</p>",
      "type": "chapter",
      "parentId": "99e64397-d0fd-442e-af2c-c9be677aff26",
      "childrenIds": [
        "98c744e6-f7a7-4ffd-833d-d7b4d7d0bd00"
      ],
      "isCollapsed": true,
      "prefix": "8.4.",
      "metadata": {}
    },
    "98c744e6-f7a7-4ffd-833d-d7b4d7d0bd00": {
      "id": "98c744e6-f7a7-4ffd-833d-d7b4d7d0bd00",
      "name": "Chat Modes",
      "content": "<p>Current Outline mode queries active outline only. All Outlines mode queries everything \u2014 your 'Second Brain'. Streaming word-by-word responses with source attribution.</p>",
      "type": "document",
      "parentId": "63cdae02-1798-4608-a55f-b05c93abbce3",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "8.4.1.",
      "metadata": {}
    },
    "7264c8d7-3b2c-4cca-81cf-5ad6df5198d4": {
      "id": "7264c8d7-3b2c-4cca-81cf-5ad6df5198d4",
      "name": "Local AI (Ollama)",
      "content": "<p>Settings > AI Provider: Cloud, Local (Ollama), or Auto (fallback). Recommended models (Gemma 4 \u2014 released April 2026): gemma-4-e4b (4GB RAM, multimodal), gemma-4-26b (16GB+ RAM), gemma-4-31b (24GB+ RAM, max quality). Legacy: llama3.2 for low-memory systems. Requires Ollama 0.20+ for Gemma 4. Custom endpoints supported. No rate limits with local AI.</p>",
      "type": "document",
      "parentId": "99e64397-d0fd-442e-af2c-c9be677aff26",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "8.5.",
      "metadata": {}
    },
    "e2bb47d2-25b4-416d-bcdb-5020ae980077": {
      "id": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "name": "Export Formats (40+)",
      "content": "<p>Export outlines to over 40 formats via the Share button or dropdown menu.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "872014a8-4b50-4784-bb46-808eb1178b54",
        "82562c03-15ef-491f-9df4-5fcbeb07165b",
        "91dbbaa0-3564-41f9-805e-685711c757be",
        "3b4b0f0e-9b8d-4839-a1f5-b046c524d210",
        "da903cf5-e4e1-4d1f-a70e-77ce8d943c48",
        "cb7711e0-1abf-4c26-bd1f-12fa296216de"
      ],
      "isCollapsed": true,
      "prefix": "9.",
      "metadata": {}
    },
    "872014a8-4b50-4784-bb46-808eb1178b54": {
      "id": "872014a8-4b50-4784-bb46-808eb1178b54",
      "name": "Documents",
      "content": "<p>PDF, Markdown, Plain Text, HTML (collapsible), Interactive Outline (sidebar viewer), Website (8 templates), Word (.docx), LaTeX, ePub, Blog HTML.</p>",
      "type": "document",
      "parentId": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "9.1.",
      "metadata": {}
    },
    "82562c03-15ef-491f-9df4-5fcbeb07165b": {
      "id": "82562c03-15ef-491f-9df4-5fcbeb07165b",
      "name": "Outliners",
      "content": "<p>OPML (standard interchange), JSON/IDM (native), Org-mode, TaskPaper, Workflowy/Dynalist, OmniOutliner.</p>",
      "type": "document",
      "parentId": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "9.2.",
      "metadata": {}
    },
    "91dbbaa0-3564-41f9-805e-685711c757be": {
      "id": "91dbbaa0-3564-41f9-805e-685711c757be",
      "name": "Note Apps",
      "content": "<p>Obsidian (wiki-links), Notion, Evernote (ENEX), Roam Research, Logseq, Bear, OneNote.</p>",
      "type": "document",
      "parentId": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "9.3.",
      "metadata": {}
    },
    "3b4b0f0e-9b8d-4839-a1f5-b046c524d210": {
      "id": "3b4b0f0e-9b8d-4839-a1f5-b046c524d210",
      "name": "Mind Maps",
      "content": "<p>FreeMind (.mm), XMind (.xmind).</p>",
      "type": "document",
      "parentId": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "9.4.",
      "metadata": {}
    },
    "da903cf5-e4e1-4d1f-a70e-77ce8d943c48": {
      "id": "da903cf5-e4e1-4d1f-a70e-77ce8d943c48",
      "name": "Data",
      "content": "<p>CSV (flattened tabular), JSON Tree (hierarchical), XML, YAML.</p>",
      "type": "document",
      "parentId": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "9.5.",
      "metadata": {}
    },
    "cb7711e0-1abf-4c26-bd1f-12fa296216de": {
      "id": "cb7711e0-1abf-4c26-bd1f-12fa296216de",
      "name": "Presentations & Media",
      "content": "<p>Reveal.js (HTML slides), Teleprompter (script format), Podcast (AI-generated MP3), Twitter/X Thread.</p>",
      "type": "document",
      "parentId": "e2bb47d2-25b4-416d-bcdb-5020ae980077",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "9.6.",
      "metadata": {}
    },
    "89d7d15e-b587-4cdd-987d-f73afd03271a": {
      "id": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "name": "Interactive Outline Export",
      "content": "<p>New export format that produces a read-only IdiamPro-style viewer as a self-contained HTML file.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "6e362b9a-35e6-4887-893a-9098c5a02ed0",
        "eaaf1a26-2677-4a0e-878d-0f7d27108eb3",
        "9649a29f-7b45-4812-b4b3-ade3db661ab8",
        "c66c78c7-2393-4142-aaec-8e107737a88a",
        "0e661ffb-5d5b-4f37-a02a-04e4e85f2e01",
        "1d932440-057c-44d8-8349-c7a2eb5a314e"
      ],
      "isCollapsed": true,
      "prefix": "10.",
      "metadata": {}
    },
    "6e362b9a-35e6-4887-893a-9098c5a02ed0": {
      "id": "6e362b9a-35e6-4887-893a-9098c5a02ed0",
      "name": "Sidebar Navigation",
      "content": "<p>Collapsible tree on the left with node icons, prefixes, depth colors, and color strips. Click to navigate. Resizable via drag handle.</p>",
      "type": "document",
      "parentId": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "10.1.",
      "metadata": {}
    },
    "eaaf1a26-2677-4a0e-878d-0f7d27108eb3": {
      "id": "eaaf1a26-2677-4a0e-878d-0f7d27108eb3",
      "name": "Content Pane",
      "content": "<p>Right pane displays selected node content with breadcrumbs, node type icon, and 'In this section' child links at the bottom.</p>",
      "type": "document",
      "parentId": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "10.2.",
      "metadata": {}
    },
    "9649a29f-7b45-4812-b4b3-ade3db661ab8": {
      "id": "9649a29f-7b45-4812-b4b3-ade3db661ab8",
      "name": "Search",
      "content": "<p>Search box filters nodes by name. Cmd+F focuses search. Matching text highlighted. Esc clears.</p>",
      "type": "document",
      "parentId": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "10.3.",
      "metadata": {}
    },
    "c66c78c7-2393-4142-aaec-8e107737a88a": {
      "id": "c66c78c7-2393-4142-aaec-8e107737a88a",
      "name": "Dark/Light Mode",
      "content": "<p>Auto-detects system preference. Toggle button to switch. Full theme with Apple-inspired colors.</p>",
      "type": "document",
      "parentId": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "10.4.",
      "metadata": {}
    },
    "0e661ffb-5d5b-4f37-a02a-04e4e85f2e01": {
      "id": "0e661ffb-5d5b-4f37-a02a-04e4e85f2e01",
      "name": "Mobile & Print",
      "content": "<p>Responsive hamburger menu on mobile. Print-friendly layout hides sidebar and shows single-column content.</p>",
      "type": "document",
      "parentId": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "10.5.",
      "metadata": {}
    },
    "1d932440-057c-44d8-8349-c7a2eb5a314e": {
      "id": "1d932440-057c-44d8-8349-c7a2eb5a314e",
      "name": "Auto-Open",
      "content": "<p>After generation, file automatically opens in default browser (Electron) or new tab (Web).</p>",
      "type": "document",
      "parentId": "89d7d15e-b587-4cdd-987d-f73afd03271a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "10.6.",
      "metadata": {}
    },
