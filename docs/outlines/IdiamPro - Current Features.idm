      ],
      "isCollapsed": true,
      "prefix": "15.",
      "metadata": {}
    },
    "1e14d2d0-2eea-44cd-aa11-9a5102e762c1": {
      "id": "1e14d2d0-2eea-44cd-aa11-9a5102e762c1",
      "name": "Create & Rename",
      "content": "<p>Create new outlines via Cmd+N or + button. Rename by double-clicking in sidebar. Delete with confirmation.</p>",
      "type": "document",
      "parentId": "7988e784-fb00-44b8-8fbe-04e5f5713a18",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "15.1.",
      "metadata": {}
    },
    "e684c1df-5f40-4200-a781-b04f0e93f9ba": {
      "id": "e684c1df-5f40-4200-a781-b04f0e93f9ba",
      "name": "Sidebar Search",
      "content": "<p>Filter outlines by name in real-time. Alphabetical sorting.</p>",
      "type": "document",
      "parentId": "7988e784-fb00-44b8-8fbe-04e5f5713a18",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "15.2.",
      "metadata": {}
    },
    "deaa1e64-76e0-47e7-aba2-49d47749a902": {
      "id": "deaa1e64-76e0-47e7-aba2-49d47749a902",
      "name": "Multi-Outline Selection",
      "content": "<p>Cmd/Ctrl+Click or Shift+Click to select multiple outlines. Bulk delete selected.</p>",
      "type": "document",
      "parentId": "7988e784-fb00-44b8-8fbe-04e5f5713a18",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "15.3.",
      "metadata": {}
    },
    "5d3028da-4a2e-4b8c-8937-0d1eff31661a": {
      "id": "5d3028da-4a2e-4b8c-8937-0d1eff31661a",
      "name": "Templates",
      "content": "<p>Create outlines from pre-built templates via New from Template command.</p>",
      "type": "document",
      "parentId": "7988e784-fb00-44b8-8fbe-04e5f5713a18",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "15.4.",
      "metadata": {}
    },
    "30580a22-8cfe-4f58-856e-e373854e517a": {
      "id": "30580a22-8cfe-4f58-856e-e373854e517a",
      "name": "File Management & Backups",
      "content": "<p>Automatic backup system and file storage management.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "61e0273a-1545-4f9b-9a82-7db54c7ac53c",
        "a5d548f3-a500-4eb5-8583-6163dbcd6b1c",
        "3ad3ddab-b77d-447a-a58b-81c04fd76b76",
        "d57fe938-15b8-429a-a921-06571f33d683",
        "c6a73694-2034-4aab-bc5a-5ee8db61ef4e"
      ],
      "isCollapsed": true,
      "prefix": "16.",
      "metadata": {}
    },
    "61e0273a-1545-4f9b-9a82-7db54c7ac53c": {
      "id": "61e0273a-1545-4f9b-9a82-7db54c7ac53c",
      "name": "Automatic Backups",
      "content": "<p>Desktop app creates timestamped backups on every save. Throttled to one per 5 minutes per outline. Last 10 backups retained. Older ones pruned automatically.</p>",
      "type": "document",
      "parentId": "30580a22-8cfe-4f58-856e-e373854e517a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "16.1.",
      "metadata": {}
    },
    "a5d548f3-a500-4eb5-8583-6163dbcd6b1c": {
      "id": "a5d548f3-a500-4eb5-8583-6163dbcd6b1c",
      "name": "Backup Recovery",
      "content": "<p>Navigate to outlines folder > backups in Finder. Rename backup file (remove _backup_timestamp) to restore.</p>",
      "type": "document",
      "parentId": "30580a22-8cfe-4f58-856e-e373854e517a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "16.2.",
      "metadata": {}
    },
    "3ad3ddab-b77d-447a-a58b-81c04fd76b76": {
      "id": "3ad3ddab-b77d-447a-a58b-81c04fd76b76",
      "name": "Storage Options",
      "content": "<p>iCloud Drive, Dropbox, Google Drive, local folders. Configurable in Settings > Data folder.</p>",
      "type": "document",
      "parentId": "30580a22-8cfe-4f58-856e-e373854e517a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "16.3.",
      "metadata": {}
    },
    "d57fe938-15b8-429a-a921-06571f33d683": {
      "id": "d57fe938-15b8-429a-a921-06571f33d683",
      "name": "External Change Detection",
      "content": "<p>Detects when outline file is modified externally. Conflict dialog lets you keep local version or reload from disk.</p>",
      "type": "document",
      "parentId": "30580a22-8cfe-4f58-856e-e373854e517a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "16.4.",
      "metadata": {}
    },
    "c6a73694-2034-4aab-bc5a-5ee8db61ef4e": {
      "id": "c6a73694-2034-4aab-bc5a-5ee8db61ef4e",
      "name": "Dirty Flag System",
      "content": "<p>Only saves outlines that have been modified in-app. Prevents unnecessary writes.</p>",
      "type": "document",
      "parentId": "30580a22-8cfe-4f58-856e-e373854e517a",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "16.5.",
      "metadata": {}
    },
    "fab392c3-fbcc-42a9-b874-2830368b97f9": {
      "id": "fab392c3-fbcc-42a9-b874-2830368b97f9",
      "name": "Settings",
      "content": "<p>Configurable via gear icon in toolbar.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "14e3861e-3f99-4373-bf00-f4cbaa5a4cdd",
        "f26a1b36-75cb-459b-9a21-8e0f03c430ea",
        "8cb357d6-374d-44e3-8ea8-0ace4299a8d6",
        "ba461d7d-97a6-44df-95a0-23024d4dc6d6",
        "1b48434f-7f42-4945-ac17-2c7e99c8f9cc"
      ],
      "isCollapsed": true,
      "prefix": "17.",
      "metadata": {}
    },
    "14e3861e-3f99-4373-bf00-f4cbaa5a4cdd": {
      "id": "14e3861e-3f99-4373-bf00-f4cbaa5a4cdd",
      "name": "Data Folder",
      "content": "<p>Choose where outlines are saved. Supports Electron file dialog and File System Access API.</p>",
      "type": "document",
      "parentId": "fab392c3-fbcc-42a9-b874-2830368b97f9",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "17.1.",
      "metadata": {}
    },
    "f26a1b36-75cb-459b-9a21-8e0f03c430ea": {
      "id": "f26a1b36-75cb-459b-9a21-8e0f03c430ea",
      "name": "Delete Confirmation",
      "content": "<p>Toggle confirmation dialog when deleting nodes.</p>",
      "type": "document",
      "parentId": "fab392c3-fbcc-42a9-b874-2830368b97f9",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "17.2.",
      "metadata": {}
    },
    "8cb357d6-374d-44e3-8ea8-0ace4299a8d6": {
      "id": "8cb357d6-374d-44e3-8ea8-0ace4299a8d6",
      "name": "AI Provider",
      "content": "<p>Cloud (Gemini), Local (Ollama with Gemma 4 by default), or Auto (tries cloud, falls back to local on rate limit).</p>",
      "type": "document",
      "parentId": "fab392c3-fbcc-42a9-b874-2830368b97f9",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "17.3.",
      "metadata": {}
    },
    "ba461d7d-97a6-44df-95a0-23024d4dc6d6": {
      "id": "ba461d7d-97a6-44df-95a0-23024d4dc6d6",
      "name": "AI Depth",
      "content": "<p>Quick (fast), Standard (balanced), Deep (thorough reasoning).</p>",
      "type": "document",
      "parentId": "fab392c3-fbcc-42a9-b874-2830368b97f9",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "17.4.",
      "metadata": {}
    },
    "1b48434f-7f42-4945-ac17-2c7e99c8f9cc": {
      "id": "1b48434f-7f42-4945-ac17-2c7e99c8f9cc",
      "name": "Ollama Configuration",
      "content": "<p>Model selection auto-detects best Gemma 4 variant based on system memory. Gemma 4 variants: e2b (1.5GB), e4b (4GB, recommended), 26b MoE (16GB+), 31b dense (24GB+). Legacy llama3.2 supported for low-memory systems. Status check for availability. Custom endpoint support. Requires Ollama 0.20+ for Gemma 4 support.</p>",
      "type": "document",
      "parentId": "fab392c3-fbcc-42a9-b874-2830368b97f9",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "17.5.",
      "metadata": {}
    },
    "703df0b4-fd42-4e95-8977-e10e6e40cdc4": {
      "id": "703df0b4-fd42-4e95-8977-e10e6e40cdc4",
      "name": "Cross-Platform Support",
      "content": "<p>IdiamPro runs on macOS, iOS, and the web.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "b2bac354-f238-4a30-bcea-97ecbe95bb0b",
        "7c17c44c-d6b5-4972-8286-fff46fb6297c",
        "a7f57854-ac29-4223-bd9e-d56d8cf517f2",
        "5b598522-5106-48c9-b774-998d96419379"
      ],
      "isCollapsed": true,
      "prefix": "18.",
      "metadata": {}
    },
    "b2bac354-f238-4a30-bcea-97ecbe95bb0b": {
      "id": "b2bac354-f238-4a30-bcea-97ecbe95bb0b",
      "name": "macOS Desktop (Electron)",
      "content": "<p>Native app with file system access, native file dialogs, auto-save, DevTools, and pending import recovery on launch.</p>",
      "type": "document",
      "parentId": "703df0b4-fd42-4e95-8977-e10e6e40cdc4",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "18.1.",
      "metadata": {}
    },
    "7c17c44c-d6b5-4972-8286-fff46fb6297c": {
      "id": "7c17c44c-d6b5-4972-8286-fff46fb6297c",
      "name": "iOS (Capacitor)",
      "content": "<p>Native iOS app with touch gestures (tap, swipe, long-press). Stacked and content view modes. Native sharing. Local file storage.</p>",
      "type": "document",
      "parentId": "703df0b4-fd42-4e95-8977-e10e6e40cdc4",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "18.2.",
      "metadata": {}
    },
    "a7f57854-ac29-4223-bd9e-d56d8cf517f2": {
      "id": "a7f57854-ac29-4223-bd9e-d56d8cf517f2",
      "name": "Web (Browser)",
      "content": "<p>Full-featured browser version. Auto-deployed via Vercel. File System Access API support. IndexedDB for data. Browser download fallback.</p>",
      "type": "document",
      "parentId": "703df0b4-fd42-4e95-8977-e10e6e40cdc4",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "18.3.",
      "metadata": {}
    },
    "5b598522-5106-48c9-b774-998d96419379": {
      "id": "5b598522-5106-48c9-b774-998d96419379",
      "name": "Responsive Design",
      "content": "<p>Adapts to all screen sizes. Mobile sidebar sheet. Touch-optimized UI on small screens.</p>",
      "type": "document",
      "parentId": "703df0b4-fd42-4e95-8977-e10e6e40cdc4",
      "childrenIds": [],
      "isCollapsed": true,
      "prefix": "18.4.",
      "metadata": {}
    },
    "09347361-9110-48b5-9892-8b716627b2eb": {
      "id": "09347361-9110-48b5-9892-8b716627b2eb",
      "name": "Help & Guides",
      "content": "<p>In-app help and documentation.</p>",
      "type": "chapter",
      "parentId": "0855ebbc-563f-40a1-a524-55b6b5c69833",
      "childrenIds": [
        "fca7ff30-3125-4c29-8bfb-b166fa68c6f5",
        "5cf18681-04b5-40b4-8dd4-7690516d30f2",
        "7e361f73-649e-4a67-ad1a-46dbf0d98ee9",
        "b23d1539-ab10-4af2-997d-0d5a819912b7"
      ],
      "isCollapsed": true,
