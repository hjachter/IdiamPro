      "id": "sp-root",
      "name": "IdiamPro - Killer Features & Selling Points - HJ",
      "content": "<p>Key differentiators and marketing messages for IdiamPro. Use these for website copy, app store descriptions, pitch decks, and sales conversations.</p>",
      "type": "root",
      "parentId": null,
      "childrenIds": [
        "26b2b7d4-2374-426f-b8d9-5bb71f64df16",
