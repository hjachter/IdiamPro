    "mtp-sc-12-1": {
      "id": "mtp-sc-12-1",
      "name": "Turn the delete confirmation on and off",
      "content": "<ol><li>In Settings, toggle the delete-confirmation off.</li><li>Delete an item.</li><li>Turn it back on and delete again.</li></ol><p><strong>Expected:</strong> With it off, deletes happen without a prompt; with it on, the prompt returns.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.1"
    },
    "mtp-sc-12-2": {
      "id": "mtp-sc-12-2",
      "name": "Use 'Don't ask again' on a confirmation",
      "content": "<ol><li>Trigger a confirmation dialog and choose Don't ask again.</li><li>Repeat the same action.</li></ol><p><strong>Expected:</strong> That specific confirmation no longer appears.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.2"
    },
    "mtp-sc-12-3": {
      "id": "mtp-sc-12-3",
      "name": "Professional mode silences prompts and tips",
      "content": "<ol><li>Turn on Professional mode.</li><li>Do actions that would normally confirm or show tips.</li></ol><p><strong>Expected:</strong> Confirmations and discovery tips are suppressed across the app.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.3"
    },
    "mtp-sc-12-4": {
      "id": "mtp-sc-12-4",
      "name": "Reset confirmation prompts",
      "content": "<ol><li>After dismissing some prompts, press Reset confirmation prompts.</li></ol><p><strong>Expected:</strong> All the previously dismissed confirmations come back.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.4"
    },
    "mtp-sc-12-5": {
      "id": "mtp-sc-12-5",
      "name": "Choose the AI provider and depth",
      "content": "<ol><li>In Settings, switch AI Provider between Cloud, Local, and Auto.</li><li>Change the AI Depth setting.</li></ol><p><strong>Expected:</strong> The provider and depth settings save and affect later AI runs.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.5"
    },
    "mtp-sc-12-6": {
      "id": "mtp-sc-12-6",
      "name": "Check local AI (Ollama) status",
      "content": "<ol><li>In Settings, pick an Ollama model and check its status.</li></ol><p><strong>Expected:</strong> The app clearly shows whether local AI is installed and running.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.6"
    },
    "mtp-sc-12-7": {
      "id": "mtp-sc-12-7",
      "name": "Manage data & privacy consent",
      "content": "<ol><li>Open Data & Privacy and review consent settings.</li></ol><p><strong>Expected:</strong> You can see and change your consent choices.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.7"
    },
    "mtp-sc-12-8": {
      "id": "mtp-sc-12-8",
      "name": "Toasts stay until dismissed",
      "content": "<ol><li>Do something that shows a toast notification.</li><li>Wait a while without touching it.</li></ol><p><strong>Expected:</strong> The toast stays on screen until you dismiss it; it doesn't fade on its own.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-settings",
      "childrenIds": [],
      "prefix": "14.12.8"
    },
