    "mtp-sc-14-1": {
      "id": "mtp-sc-14-1",
      "name": "Crash-recovery screen offers a way forward",
      "content": "<ol><li>If the app hits a serious error, look at the recovery screen.</li></ol><p><strong>Expected:</strong> Instead of a blank page you see Try Again, Go Home, and a support email.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-reliability",
      "childrenIds": [],
      "prefix": "14.14.1"
    },
    "mtp-sc-14-2": {
      "id": "mtp-sc-14-2",
      "name": "One broken area doesn't take down the whole app",
      "content": "<ol><li>If a single panel errors, check the rest of the app.</li></ol><p><strong>Expected:</strong> The rest of the app keeps working while the broken area is contained.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-reliability",
      "childrenIds": [],
      "prefix": "14.14.2"
    },
    "mtp-sc-14-3": {
      "id": "mtp-sc-14-3",
      "name": "Pending import recovers on next launch",
      "content": "<ol><li>Start an import, then close/reopen the app before it finishes.</li></ol><p><strong>Expected:</strong> On next launch you're offered to recover the pending import.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-reliability",
      "childrenIds": [],
      "prefix": "14.14.3"
    }
