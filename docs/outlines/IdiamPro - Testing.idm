    },
    "mtp-sc-8-1": {
      "id": "mtp-sc-8-1",
      "name": "Take a labeled manual backup",
      "content": "<ol><li>Click the Shield icon.</li><li>Create a backup and give it a label.</li></ol><p><strong>Expected:</strong> A labeled snapshot of your outline is saved.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-backup",
      "childrenIds": [],
      "prefix": "14.8.1"
    },
    "mtp-sc-8-2": {
      "id": "mtp-sc-8-2",
      "name": "Preview and restore an older snapshot",
      "content": "<ol><li>Open the Restore tab.</li><li>Preview an older snapshot, then restore it.</li></ol><p><strong>Expected:</strong> You can preview before restoring, and restoring brings back that earlier version.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-backup",
      "childrenIds": [],
      "prefix": "14.8.2"
    },
    "mtp-sc-8-3": {
      "id": "mtp-sc-8-3",
      "name": "Auto-snapshot before an AI change",
      "content": "<ol><li>Run any AI transform on an outline.</li><li>Check the backup list right after.</li></ol><p><strong>Expected:</strong> A snapshot was taken automatically just before the AI change.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-backup",
      "childrenIds": [],
      "prefix": "14.8.3"
    },
    "mtp-sc-8-4": {
      "id": "mtp-sc-8-4",
      "name": "Save an AI result as a new outline (original untouched)",
      "content": "<ol><li>Run an AI transform and choose Save as new outline.</li><li>Check the original and the sidebar.</li></ol><p><strong>Expected:</strong> The original outline is unchanged and the new derivative appears nested under it in the sidebar.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-backup",
      "childrenIds": [],
      "prefix": "14.8.4"
    },
    "mtp-sc-8-5": {
      "id": "mtp-sc-8-5",
      "name": "Old snapshots are pruned automatically",
      "content": "<ol><li>Create many backups over time.</li><li>Look at how many are kept.</li></ol><p><strong>Expected:</strong> Only roughly the newest 20 snapshots are retained; older ones are cleaned up.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-backup",
      "childrenIds": [],
      "prefix": "14.8.5"
    },
    "mtp-sc-8-6": {
      "id": "mtp-sc-8-6",
      "name": "Recover a backup from Finder",
      "content": "<ol><li>Open the backups folder in Finder and locate a backup file.</li></ol><p><strong>Expected:</strong> Backup files are present on disk and can be recovered manually if needed.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-backup",
      "childrenIds": [],
      "prefix": "14.8.6"
    },
    "mtp-area-files": {
      "id": "mtp-area-files",
      "name": "Outline Management & Files",
      "content": "",
      "type": "chapter",
      "parentId": "manual-plan-full",
      "childrenIds": [
        "mtp-sc-9-1",
        "mtp-sc-9-2",
