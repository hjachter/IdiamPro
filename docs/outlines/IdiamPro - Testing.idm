        "mtp-sc-7-5",
        "mtp-sc-7-6",
        "mtp-sc-7-7"
      ],
      "prefix": "14.7",
      "isCollapsed": true
    },
    "mtp-sc-7-1": {
      "id": "mtp-sc-7-1",
      "name": "Export to PDF",
      "content": "<ol><li>Export the current outline to PDF and open it.</li></ol><p><strong>Expected:</strong> A clean PDF of the outline is produced.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.1"
    },
    "mtp-sc-7-2": {
      "id": "mtp-sc-7-2",
      "name": "Export to Markdown or OPML",
      "content": "<ol><li>Export to Markdown, then to OPML.</li></ol><p><strong>Expected:</strong> Both files export and reflect the outline's structure.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.2"
    },
    "mtp-sc-7-3": {
      "id": "mtp-sc-7-3",
      "name": "Generate an interactive HTML viewer",
      "content": "<ol><li>Generate the Interactive Outline HTML and open it.</li></ol><p><strong>Expected:</strong> A self-contained web viewer opens with your collapsible outline.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.3"
    },
    "mtp-sc-7-4": {
      "id": "mtp-sc-7-4",
      "name": "Generate a website from a template",
      "content": "<ol><li>Choose Generate a Website and pick a template.</li></ol><p><strong>Expected:</strong> A website version of the outline is produced in the chosen style.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.4"
    },
    "mtp-sc-7-5": {
      "id": "mtp-sc-7-5",
      "name": "Generate a podcast MP3",
      "content": "<ol><li>Generate a Podcast, choosing style, voice, and length.</li></ol><p><strong>Expected:</strong> An MP3 is produced matching your settings.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.5"
    },
    "mtp-sc-7-6": {
      "id": "mtp-sc-7-6",
      "name": "Share as a YouTube package",
      "content": "<ol><li>Run Share as YouTube package.</li></ol><p><strong>Expected:</strong> You receive the full set of outputs (script, description, etc.) for a video.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.6"
    },
    "mtp-sc-7-7": {
      "id": "mtp-sc-7-7",
      "name": "Share just one branch",
      "content": "<ol><li>Select a single branch and share only that.</li></ol><p><strong>Expected:</strong> Only the chosen branch is exported/shared, not the whole outline.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-export",
      "childrenIds": [],
      "prefix": "14.7.7"
    },
    "mtp-area-backup": {
      "id": "mtp-area-backup",
      "name": "Backup, Restore & Data Protection",
      "content": "",
      "type": "chapter",
      "parentId": "manual-plan-full",
      "childrenIds": [
        "mtp-sc-8-1",
        "mtp-sc-8-2",
        "mtp-sc-8-3",
        "mtp-sc-8-4",
        "mtp-sc-8-5",
