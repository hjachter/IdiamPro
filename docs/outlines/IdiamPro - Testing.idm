      ],
      "prefix": "14.9",
      "isCollapsed": true
    },
    "mtp-sc-9-1": {
      "id": "mtp-sc-9-1",
      "name": "Create, rename, and delete outlines in the sidebar",
      "content": "<ol><li>Create a new outline, rename it, then delete it.</li></ol><p><strong>Expected:</strong> Each action works and the sidebar updates immediately.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.1"
    },
    "mtp-sc-9-2": {
      "id": "mtp-sc-9-2",
      "name": "Select multiple outlines and delete them together",
      "content": "<ol><li>Multi-select two outlines in the sidebar and delete them.</li></ol><p><strong>Expected:</strong> Both are removed in one bulk action (with confirmation).</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.2"
    },
    "mtp-sc-9-3": {
      "id": "mtp-sc-9-3",
      "name": "Start a new outline from a template",
      "content": "<ol><li>Create a new outline and pick the Meeting Notes template.</li></ol><p><strong>Expected:</strong> The new outline opens pre-filled with the template's structure.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.3"
    },
    "mtp-sc-9-4": {
      "id": "mtp-sc-9-4",
      "name": "Link between outlines and jump across",
      "content": "<ol><li>Insert a cross-outline link item pointing at another outline.</li><li>Click it to jump.</li><li>Delete the target outline and click the link again.</li></ol><p><strong>Expected:</strong> The link jumps to the other outline; when the target is gone the app handles it gracefully instead of breaking.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.4"
    },
    "mtp-sc-9-5": {
      "id": "mtp-sc-9-5",
      "name": "Choose where outlines are stored",
      "content": "<ol><li>In Settings, choose a different data folder.</li></ol><p><strong>Expected:</strong> Outlines are read from and saved to the folder you chose.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.5"
    },
    "mtp-sc-9-6": {
      "id": "mtp-sc-9-6",
      "name": "App notices an outline changed on disk",
      "content": "<ol><li>Edit an outline's file outside the app while it's loaded but unedited in-app.</li><li>Return to the app.</li></ol><p><strong>Expected:</strong> The app reloads the newer version without wiping your work.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.6"
    },
    "mtp-sc-9-7": {
      "id": "mtp-sc-9-7",
      "name": "Unedited outlines are never overwritten",
      "content": "<ol><li>Open an outline but don't edit it.</li><li>Switch away and check the file's modified time.</li></ol><p><strong>Expected:</strong> The file isn't rewritten because you didn't change it (dirty-flag protection).</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-files",
      "childrenIds": [],
      "prefix": "14.9.7"
    },
