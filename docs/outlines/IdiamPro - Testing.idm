    },
    "mtp-sc-13-2": {
      "id": "mtp-sc-13-2",
      "name": "Layout adapts to a narrow window",
      "content": "<ol><li>Shrink the window to a narrow/mobile width.</li></ol><p><strong>Expected:</strong> The layout reflows and the sidebar becomes a slide-in sheet.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-crossplatform",
      "childrenIds": [],
      "prefix": "14.13.2"
    },
    "mtp-sc-13-3": {
      "id": "mtp-sc-13-3",
      "name": "Dark and light mode",
      "content": "<ol><li>Let the app follow the system theme.</li><li>Then manually toggle between dark and light.</li></ol><p><strong>Expected:</strong> The app follows the system by default and honors your manual choice.</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-crossplatform",
      "childrenIds": [],
      "prefix": "14.13.3"
    },
    "mtp-sc-13-4": {
      "id": "mtp-sc-13-4",
      "name": "iOS touch gestures (device/simulator)",
      "content": "<ol><li>On an iPhone or the iOS simulator, tap an item, tap-again to edit, swipe to indent/outdent, and long-press to drag.</li></ol><p><strong>Expected:</strong> Each gesture does the expected thing. (Requires a real device or Xcode simulator.)</p><p><strong>Result:</strong> ☐ Pass ☐ Fail — Notes: ______________________________</p>",
      "type": "document",
      "parentId": "mtp-area-crossplatform",
      "childrenIds": [],
      "prefix": "14.13.4"
